<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_partner_bank_form_inherit_l10n_ec" model="ir.ui.view">
        <field name="name">res.partner.bank.form.inherit</field>
        <field name="model">res.partner.bank</field>
        <field name="inherit_id" ref="base.view_partner_bank_form"/>
        <field name="arch" type="xml">
            <field name="bank_id" position="after">
                <field name="l10n_ec_account_type"/>
                <field name="l10n_ec_account_valid"
                       invisible="l10n_ec_account_type != 'credit_card'"
                       required="l10n_ec_account_type == 'credit_card'"
                />
                <field name="l10n_ec_bank_authorized_network" widget="many2many_tags"
                       options="{'no_edit': True, 'no_create': True, 'no_open': True}"
                />
            </field>
        </field>
    </record>
</odoo>
