<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
    <record id="view_res_partner_advance_route_tree" model="ir.ui.view">
        <field name="name">res.partner.advance.route.tree</field>
        <field name="model">ek.res.partner.advance.route</field>
        <field name="type">tree</field>
        <field name="arch" type="xml">
            <tree editable="bottom">
                <field name="partner_id" options="{'no_create': True, 'no_open': True}" domain="[('parent_id','=', False),('type','!=', 'delivery')]"/>
                <field name="contact_id" options="{'no_create': True, 'no_open': True}" domain="[('parent_id','=',partner_id),('parent_id','!=', False),('type','=', 'delivery')]"/>
                <field name="zone_id" options="{'no_create': True, 'no_open': True}"/>
                <field name="channel_id" options="{'no_create': True, 'no_open': True}"/>
                <field name="route_id" options="{'no_create': True, 'no_open': True}"/>
                <field name="sector_id" options="{'no_create': True, 'no_open': True}"/>
                <field name="user_id" options="{'no_create': True, 'no_open': True}"/>
                <field name="supervisor_id" options="{'no_create': True, 'no_open': True}" optional="hide"/>
                <field name="supervisor_chanel_id" options="{'no_create': True, 'no_open': True}" optional="hide"/>
                <field name="supervisor_sector_id" options="{'no_create': True, 'no_open': True}" optional="hide"/>
                <field name="supervisor_route_id" options="{'no_create': True, 'no_open': True}" optional="hide"/>
                <field name="visit_frequency" widget="many2many_tags" options="{'no_create': True, 'no_open': True}"/>
            </tree>
        </field>
    </record>

        <record id="view_res_partner_advance_route_search" model="ir.ui.view">
        <field name="name">ek.res.partner.advance.route.search</field>
        <field name="model">ek.res.partner.advance.route</field>
        <field name="type">search</field>
        <field name="arch" type="xml">
            <search>
                <field name="partner_id" />
                <field name="contact_id" />
                <field name="zone_id" />
                <field name="channel_id" />
                <field name="route_id" />
                <field name="sector_id" />
                <field name="user_id" />
                <field name="supervisor_id" />
            </search>
        </field>
    </record>

    <record id="action_res_partner_advance_route" model="ir.actions.act_window">
        <field name="name">Rutas Avanzadas</field>
        <field name="res_model">ek.res.partner.advance.route</field>
        <field name="view_mode">tree</field>
        <field name="search_view_id" ref="view_res_partner_advance_route_search"/>
    </record>

    <menuitem action="action_res_partner_advance_route"
            id="menu_res_partner_advance_route"
            parent="contacts.menu_localisation"
            groups="ek_l10n_ec_ote.group_ec_delivery_frequency"
    />

    </data>
</odoo>