<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_country_city_form_view" model="ir.ui.view">
        <field name="name">ek.res.country.city.form</field>
        <field name="model">ek.res.country.city</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="code" placeholder="Código"/>/<field name="name" placeholder="Nombre"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="country_id"/>
                        </group>
                        <group>
                            <field name="state_id" domain="[('country_id', '=', country_id)]" required="1"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="res_country_city_tree_view" model="ir.ui.view">
        <field name="name">ek.res.country.city.tree</field>
        <field name="model">ek.res.country.city</field>
        <field name="arch" type="xml">
            <tree>
                <field name="code"/>
                <field name="name"/>
                <field name="state_id"/>
                <field name="country_id"/>
            </tree>
        </field>
    </record>

    <record id="res_country_city_search_view" model="ir.ui.view">
        <field name="name">ek.res.country.city.search</field>
        <field name="model">ek.res.country.city</field>
        <field name="arch" type="xml">
            <search>
                <field name="code"/>
                <field name="name"/>
                <field name="state_id"/>
                <field name="country_id"/>
                <group expand="1" string="Group By">
                    <filter string="Estado/Provincia" name="state_id" context="{'group_by': 'state_id'}"/>
                    <filter name="country_id" context="{'group_by': 'country_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="res_country_city_act_window" model="ir.actions.act_window">
        <field name="name">Ciudades</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">ek.res.country.city</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="oe_view_nocontent_create">
                Cree las ciudades pertenecientes a un país.
            </p>
        </field>
    </record>

