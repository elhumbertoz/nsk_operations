<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- View ek.boats.information.itmes View Tree -->
    <record id="view_ek_boats_information_itmes_tree" model="ir.ui.view">
        <field name="name">view.ek.boats.information.itmes.tree</field>
        <field name="model">ek.boats.information.itmes</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
            </tree>
        </field>
    </record>

    <!-- View ek.boats.information.itmes form -->
    <record id="view_ek_boats_information_itmes_form" model="ir.ui.view">
        <field name="name">view.ek.boats.information.itmes.form</field>
        <field name="model">ek.boats.information.itmes</field>
        <field name="arch" type="xml">
            <form string="Ek Boats Information Itmes">
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" placeholder="Name..."/>
                        </h1>
                    </div>
                </sheet>
            </form>
        </field>
    </record>

    <!-- View ek.boats.information.itmes search -->
    <record id="view_ek_boats_information_itmes_search" model="ir.ui.view">
        <field name="name">view.ek.boats.information.itmes.search</field>
        <field name="model">ek.boats.information.itmes</field>
        <field name="arch" type="xml">
            <search>
                <group expand="1" string="Group By">
                    <filter string="Name" name="name" domain="[]" context="{'group_by':'name'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action ek.boats.information.itmes -->
    <record id="action_ek_boats_information_itmes" model="ir.actions.act_window">
        <field name="name">Ek Boats Information Itmes</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">ek.boats.information.itmes</field>
        <field name="view_mode">tree,form</field>
        <field name="domain">[]</field>
        <field name="context">{}</field>
        <field name="help" type="html">
            <p class="oe_view_nocontent_create">
                There is no examples click here to add new Ek Boats Information Itmes.
            </p>
        </field>
    </record>

</odoo>
