<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Kanban View for Operation Requests -->
    <record id="ek_operation_request_kanban" model="ir.ui.view">
        <field name="name">ek.operation.request.kanban</field>
        <field name="model">ek.operation.request</field>
        <field name="arch" type="xml">
            <kanban default_group_by="stage_id" class="o_kanban_small_column" records_draggable="true" sample="1">
                <field name="stage_id"/>
                <field name="name"/>
                <field name="ek_ship_registration_id"/>
                <field name="journey_crew_id"/>
                <field name="res_partner_id"/>
                <field name="type_id"/>
                <field name="agent_user_id"/>
                <field name="processing_status"/>
                <field name="color"/>
                <templates>
                    <t t-name="kanban-box">
                        <div t-attf-class="#{!selection_mode ? kanban_color(record.color.raw_value) : ''} oe_kanban_global_click">
                            <div class="o_dropdown_kanban dropdown">
                                <a class="dropdown-toggle o-no-caret btn" role="button" data-toggle="dropdown" data-bs-toggle="dropdown" href="#" aria-label="Dropdown menu" title="Dropdown menu">
                                    <span class="fa fa-ellipsis-v"/>
                                </a>
                                <div class="dropdown-menu" role="menu">
                                    <t t-if="widget.editable"><a role="menuitem" type="edit" class="dropdown-item">Edit</a></t>
                                    <t t-if="widget.deletable"><a role="menuitem" type="delete" class="dropdown-item">Delete</a></t>
                                    <ul class="oe_kanban_colorpicker" data-field="color"/>
                                </div>
                            </div>
                            <div class="oe_kanban_details">
                                <strong class="o_kanban_record_title">
                                    <field name="display_name"/>
                                </strong>
                                <div class="o_kanban_record_subtitle">
                                    <field name="type_id"/>
                                </div>
                                <div class="mt-1">
                                    <i class="fa fa-ship" title="Ship"/><span class="ms-1"><field name="ek_ship_registration_id"/></span>
                                </div>
                                <div t-if="record.journey_crew_id.raw_value">
                                    <i class="fa fa-road" title="Travel"/><span class="ms-1"><field name="journey_crew_id"/></span>
                                </div>
                                <div>
                                    <i class="fa fa-user" title="Customer"/><span class="ms-1"><field name="res_partner_id"/></span>
                                </div>
                                <div class="o_kanban_record_bottom mt-2">
                                    <div class="oe_kanban_bottom_left">
                                        <field name="processing_status" widget="label_selection" options="{'classes': {'developing': 'primary', 'done': 'success', 'cancel': 'danger'}}"/>
                                    </div>
                                    <div class="oe_kanban_bottom_right">
                                        <field name="agent_user_id" widget="many2one_avatar_user"/>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Update Actions to include Kanban view (but not as default) -->
    <record id="ek_l10n_shipping_operations.ek_operation_request_act_window" model="ir.actions.act_window">
        <field name="view_mode">tree,kanban,form</field>
    </record>
    
    <record id="ek_l10n_shipping_operations.ek_operation_request_enhanced_act_window" model="ir.actions.act_window">
        <field name="view_mode">tree,kanban,form</field>
    </record>
    
    <record id="ek_l10n_shipping_operations.ek_operation_request_from_journey_act_window" model="ir.actions.act_window">
        <field name="view_mode">tree,kanban,form</field>
    </record>
</odoo>
