<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <record id="view_ek_boats_information_regimens_form" model="ir.ui.view">
    <field name="name">ek.boats.information.regimen.form</field>
    <field name="model">ek.boats.information</field>
    <field name="priority">10</field>
    <field name="arch" type="xml">
      <form string="">
        <header>
          <button name="action_cancelled_request" string="Cancelado" type="object" icon="fa-check-circle" class="oe_stat_button" invisible="state not in ['draft']"/>
          <button name="action_finalize_travel" string="Finalizado" type="object" class="oe_stat_button" invisible="1"/>
          <button name="action_create_operation_request"
                  string="Crear Solicitud de Operación"
                  type="object"
                  class="btn-primary"
                  icon="fa-plus-circle"
                  invisible="state in ['cancelled']"
                  help="Crea una solicitud de operación a partir de los bultos registrados en este contenedor"/>

          <field name="state" widget="statusbar" statusbar_visible="draft"/>
        </header>
        <sheet>
          <div class="oe_button_box" name="button_box">
            <button class="oe_stat_button" name="action_open_documents_request" type="object" icon="fa-share-square-o">
              <field string="Solicitudes" name="request_count" widget="statinfo"/>
            </button>
            <button class="oe_stat_button" name="action_open_documents_sale_order" type="object" icon="fa-file-text-o">
              <field string="Ventas" name="sale_order_count" widget="statinfo"/>
            </button>
            <button class="oe_stat_button" name="action_open_documents_account_move" type="object" icon="fa-pencil-square-o">
              <field string="Facturas" name="invoice_count" widget="statinfo"/>
            </button>
            <button class="oe_stat_button" name="action_open_documents_purchase_order" type="object" icon="fa-pencil-square-o">
              <field string="Compras" name="purchase_count" widget="statinfo"/>
            </button>
          </div>
          <div class="oe_title">
            <h1>
              <field name="name" placeholder="Name" readonly="1"/>
            </h1>
            <h1>
              <field name="ref_container" placeholder="Ref."/>
            </h1>
          </div>

          <group>
            <group>
              <field name="validate_finalized" invisible="1"/>
              <field name="ship_name_id" required="1" readonly="state in ['process','done','cancelled']" options="{'no_quick_create': True, 'no_create_edit': True, 'no_open': True}"/>
              <field name="company_id" force_save="1" readonly="1" groups="base.group_multi_company" options="{'no_quick_create': True, 'no_create_edit': True, 'no_open': True}"/>
              <field name="supplies_detail"/>
              <field name="supplier_ids" widget="many2many_tags" options="{'no_quick_create': True, 'no_create_edit': True, 'no_open': True}"/>
              <field name="custom_agent"/>
            </group>
            <group>
              <field name="shipper_id"/>
              <field name="shipping_line_id"/>
              <field name="type_container_id"/>
              <field name="type_move_container"/>
              <field name="load_number"/>
              <field name="number_container"/>
              <field name="seal_number"/>
              <field name="bl_number"/>
              <field name="booking_number"/>
              <field name="type_move_fcl_lcl"/>
              <field name="consignee_id" options="{'no_create': True}"/>
            </group>
          </group>

          <group>
            <group string="Logística Portuaria">
              <field name="ek_res_world_seaports_id" required="1" readonly="state in ['process','done','cancelled']" options="{'no_quick_create': True, 'no_create_edit': True, 'no_open': True}" string="Origin Location (POL)"/>
              <field name="ek_res_world_seaports_d_id" options="{'no_quick_create': True, 'no_create_edit': True, 'no_open': True}" string="Destination Location (POD)"/>
              <field name="on_board_date"/>
              <field name="eta" string="Departure Port Of Origin"/>
              <field name="ata" string="Arrival of Date"/>
            </group>

            <group string="Cantidades y Totales">
              <field name="total_gross_weight" readonly="1"/>
              <field name="total_packages_count" readonly="1"/>
              <field name="value_of_container" string="Total FOB" decoration-bf="1"/>
              <field name="etd" string="Transfer Date"/>
              <field name="atd" string="Desconsolidation Date"/>
              <field name="rcd" string="Return Container Date"/>
            </group>
          </group>

          <group>
            <group string="Date ">
              <field name="create_date"/>
              <field name="date_finished"/>
            </group>
            <group/>
          </group>

          <notebook>
            <page string="Items en Contenedor">
              <button name="open_items_container" type="object" string="Configuración Avanzada de Items" class="btn btn-primary mb-2" icon="fa-arrows-alt"/>
              <field name="ek_produc_packages_goods_ids">
                <tree editable="bottom" decoration-info="match_confidence &gt;= 80" decoration-warning="match_confidence &lt; 80 and match_confidence &gt; 0">
                  <field name="sequence" widget="handle"/>
                  <field name="creation_indicator" string=" " readonly="1"/>
                  <field name="product_id"
                         domain="[('categ_id', '=', %(ek_l10n_shipping_operations_charging_regimes.product_category_regime_70)d)]"
                         options="{'no_create': True}"
                         context="{
                           'default_categ_id': %(ek_l10n_shipping_operations_charging_regimes.product_category_regime_70)d,
                           'default_type': 'consu',
                           'default_detailed_type': 'consu',
                           'default_purchase_ok': True,
                           'default_sale_ok': True
                         }"
                         width="400px"/>
                  <field name="extracted_name" optional="show" string="Descripción Proveedor" class="text-muted italic"/>
                  <field name="ship_id" options="{'no_create': True}"/>
                  <field name="is_not_dispatched" string="No Vino"/>
                  <field name="packages_count" optional="hide"/>
                  <field name="match_confidence" string="% Match IA" widget="progressbar"/>
                  <field name="tariff_item" optional="show" string="Partida"/>
                  <field name="id_hs_copmt_cd" optional="show" string="Comp."/>
                  <field name="id_hs_spmt_cd" optional="show" string="Suplem."/>
                  <field name="gross_weight" sum="total"/>
                  <field name="quantity" sum="total"/>
                  <field name="fob" optional="show"/>
                  <field name="total_fob" sum="Total FOB"/>
                  <field name="invoice_number" string="N. Factura"/>
                  <field name="supplier" string="Proveedor" optional="hide" />
                  <field name="ek_ship_registration_id" column_invisible="1"/>
                  <field name="ek_boats_information_id" column_invisible="1"/>
                  <field name="id_bl" optional="hide"/>
                </tree>
              </field>

              <group>
                <group string="Carga de Facturas">
                  <field name="invoice_attachment_ids"
                         widget="many2many_binary"/>
                  <label for="action_extract_invoices_with_ai" string=" "/>
                  <button name="action_extract_invoices_with_ai"
                          string="Extraer Facturas con IA"
                          type="object"
                          class="btn-success"
                          icon="fa-file-pdf-o"
                          invisible="not invoice_attachment_ids or ai_extraction_status_fc == 'processing'"/>
                </group>
                <group string="Estado">
                   <field name="ai_extraction_status_fc" widget="badge"
                          string="Estado Facturas"
                          decoration-success="ai_extraction_status_fc=='completed'"
                          decoration-warning="ai_extraction_status_fc=='processing'"
                          decoration-danger="ai_extraction_status_fc=='error'"/>
                   <field name="ai_extraction_progress" widget="progressbar" 
                          invisible="ai_extraction_status_fc != 'processing'"
                          label="Progreso"/>
                   <field name="ai_extraction_message" 
                          invisible="not ai_extraction_message"
                          style="font-size: 0.85rem;" class="text-muted"/>
                </group>
              </group>
            </page>
            <page string="BL">
                <group>
                    <group string="Carga de BL">
                        <field name="bl_attachment_ids"
                               widget="many2many_binary"
                               string="Bill of Lading"/>
                        <field name="bl_attachment_filename" invisible="1"/>
                        <label for="action_extract_bl_with_ai" string=" "/>
                        <button name="action_extract_bl_with_ai"
                                string="Extraer BL con IA"
                                type="object"
                                class="btn-primary"
                                icon="fa-magic"
                                invisible="not bl_attachment_ids or ai_extraction_status_bl == 'processing'"/>
                    </group>
                    <group string="Estado BL">
                        <field name="ai_extraction_status_bl" widget="badge"
                               string="Estado BL"
                               decoration-success="ai_extraction_status_bl=='completed'"
                               decoration-warning="ai_extraction_status_bl=='processing'"
                               decoration-danger="ai_extraction_status_bl=='error'"/>
                    </group>
                </group>
            </page>
            <page string="Notas">
              <field name="notes" nolabel="1"/>
            </page>
          </notebook>
        </sheet>
        <div class="oe_chatter" name="oe_chatter">
          <field name="message_follower_ids"/>
          <field name="message_ids"/>
          <field name="activity_ids"/>
        </div>
      </form>
    </field>
  </record>
  <record id="ek_boats_information_tree_reguimen" model="ir.ui.view">
    <field name="name">ek.boats.information.tree.reguimen</field>
    <field name="model">ek.boats.information</field>
    <field name="priority">1</field>
    <field name="arch" type="xml">
      <tree create="true" edit="true" expand="true" multi_edit="1" sample="1" js_class="hr_employee_list">
        <field name="name" string="Name"/>
        <field name="ref_container" string="Ref. Container"/>
        <field name="create_date" string="Creado el"/>
        <field name="state" string="Estado"/>
      </tree>
    </field>
  </record>
  <record id="ek_boats_information_search_regimen" model="ir.ui.view">
    <field name="name">ek.boats.information.search.reguime</field>
    <field name="model">ek.boats.information</field>
    <field name="arch" type="xml">
      <search>
        <searchpanel>
          <field name="ship_name_id" string="Regimen" icon="fa-archive" enable_counters="1"/>
        </searchpanel>
      </search>

    </field>
  </record>

  <record model="ir.actions.act_window" id="ek_boats_container_information_act">
    <field name="name">Contenedores</field>
    <field name="res_model">ek.boats.information</field>
    <field name="view_mode">tree,form</field>
    <field name="search_view_id" ref="ek_boats_information_search_regimen"/>
    <field name="domain">[("assigned_regimen_70","=",True)]</field>
    <field name="view_ids" eval="[(5, 0, 0), (0, 0, {'view_mode': 'tree', 'view_id': ref('ek_boats_information_tree_reguimen')}), (0, 0, {'view_mode': 'form', 'view_id': ref('view_ek_boats_information_regimens_form')})]"/>

  </record>

  <record id="menu_boat" model="ir.ui.menu">
    <field name="action" ref="ek_l10n_shipping_operations_charging_regimes.ek_boats_container_information_act"/>
    <field name="active" eval="True"/>
    <field name="groups_id" eval="[(6, 0, [])]"/>
    <field name="name">Contenedores</field>
    <field name="parent_id" ref="ek_l10n_shipping_operations.menu_boat_information_principal"/>
    <field name="sequence">3</field>
    <field name="web_icon" eval="False"/>
  </record>


  <record id="ek_product_packagens_goods_search" model="ir.ui.view">
    <field name="name">ek.product.packagens.goods.search</field>
    <field name="model">ek.product.packagens.goods</field>
    <field name="arch" type="xml">
      <search>
        <field name="product_id"/>
        <field name="extracted_name"/>
        <field name="tariff_item"/>
        <field name="invoice_number"/>
        <field name="supplier"/>
        <field name="id_bl"/>
        <field name="ek_boats_information_id"/>
        <field name="ship_id"/>

        <filter string="No Despachados" name="not_dispatched" domain="[('is_not_dispatched', '=', True)]"/>
        <filter string="Nuevos Productos" name="new_products" domain="[('is_new_product', '=', True)]"/>
        <separator/>
        <filter string="Confianza Alta (&gt;80%)" name="high_confidence" domain="[('match_confidence', '&gt;=', 80)]"/>
        <filter string="Confianza Baja (&lt;80%)" name="low_confidence" domain="[('match_confidence', '&lt;', 80), ('match_confidence', '&gt;', 0)]"/>

        <group expand="0" string="Agrupar Por">
          <filter string="Producto" name="group_by_product" context="{'group_by': 'product_id'}"/>
          <filter string="Factura" name="group_by_invoice" context="{'group_by': 'invoice_number'}"/>
          <filter string="Proveedor" name="group_by_supplier" context="{'group_by': 'supplier'}"/>
          <filter string="Contenedor" name="group_by_container" context="{'group_by': 'ek_boats_information_id'}"/>
          <filter string="Buque Destino" name="group_by_ship" context="{'group_by': 'ship_id'}"/>
        </group>
      </search>
    </field>
  </record>

  <record id="ek_product_packagens_goods_form" model="ir.ui.view">
    <field name="name">ek.product.packagens.goods.form</field>
    <field name="model">ek.product.packagens.goods</field>
    <field name="arch" type="xml">
      <form string="Item de Contenedor">
        <sheet>
          <div class="oe_title">
            <label for="product_id" string="Producto"/>
            <h1><field name="product_id" options="{'no_create': True}"/></h1>
            <field name="creation_indicator" readonly="1" class="oe_inline"/>
            <span invisible="not is_new_product" class="text-muted"> (Creado automáticamente)</span>
          </div>
          <group>
            <group string="Información del Documento">
                <field name="extracted_name" string="Desc. Proveedor"/>
                <field name="invoice_number"/>
                <field name="supplier"/>
                <field name="id_bl"/>
            </group>
            <group string="Matching e IA">
                <field name="match_confidence" widget="progressbar" string="Confianza IA"/>
                <field name="is_new_product" readonly="1"/>
                <field name="tariff_item" string="Partida Arancelaria"/>
                <field name="id_hs_copmt_cd" string="Código Complementario"/>
                <field name="id_hs_spmt_cd" string="Código Suplementario"/>
            </group>
        </group>
          <group>
            <group string="Cantidades y Logística">
                <field name="quantity"/>
                <field name="uom_id"/>
                <field name="gross_weight"/>
                <field name="packages_count"/>
                <field name="commercial_unit"/>
            </group>
            <group string="Valores (FOB)">
                <field name="fob"/>
                <field name="total_fob" decoration-bf="1"/>
                <field name="is_not_dispatched"/>
                <field name="ship_id"/>
            </group>
          </group>
          <notebook>
            <page string="Observaciones">
                <field name="observation" placeholder="Notas adicionales..."/>
            </page>
            <page string="Referencias de Sistema">
                <group>
                    <field name="ek_boats_information_id" readonly="1"/>
                    <field name="ek_ship_registration_id" readonly="1"/>
                    <field name="date_request" readonly="1"/>
                </group>
            </page>
          </notebook>
        </sheet>
      </form>
    </field>
  </record>

  <record id="ek_product_packagens_goods_tree_items" model="ir.ui.view">
    <field name="name">ek.product.packagens.goods.tree</field>
    <field name="model">ek.product.packagens.goods</field>
    <field name="arch" type="xml">
      <tree editable="bottom" decoration-info="match_confidence &gt;= 80" decoration-warning="match_confidence &lt; 80 and match_confidence &gt; 0">
        <header>
          <button name="delete_table_70" type="object" string="Vaciar Tabla" class="btn-danger" icon="fa-trash" />
        </header>
        <field name="sequence" widget="handle"/>
        <field name="creation_indicator" string=" " readonly="1"/>
        <field name="product_id" options="{'no_create': True}" width="400px"/>
        <field name="extracted_name" string="Descripción Proveedor" class="text-muted italic"/>
        <field name="ship_id" options="{'no_create': True}"/>
        <field name="is_not_dispatched" string="No Vino"/>
        <field name="match_confidence" widget="progressbar"/>
        <field name="tariff_item" optional="show" string="Partida"/>
        <field name="id_hs_copmt_cd" optional="show" string="Comp."/>
        <field name="id_hs_spmt_cd" optional="show" string="Suplem."/>
        <field name="quantity" />
        <field name="gross_weight" />
        <field name="fob"/>
        <field name="total_fob" sum="Total FOB"/>
        <field name="invoice_number" />
        <field name="supplier" />
        <field name="id_bl" />
      </tree>
    </field>
  </record>
  <record id="ek_product_packagens_goods_tree_items_request" model="ir.ui.view">
    <field name="name">ek.product.packagens.goods.tree.request</field>
    <field name="model">ek.product.packagens.goods</field>
    <field name="inherit_id" ref="ek_l10n_shipping_operations_charging_regimes.ek_product_packagens_goods_tree_items"/>
    <field name="arch" type="xml">
      <xpath expr="//field[@name='product_id']" position="after">
        <field name="customs_description" />
      </xpath>
    </field>
  </record>
  <record id="ek_product_packagens_goods_form_request" model="ir.ui.view">
    <field name="name">ek.product.packagens.goods.form.request</field>
    <field name="model">ek.product.packagens.goods</field>
    <field name="inherit_id" ref="ek_l10n_shipping_operations_charging_regimes.ek_product_packagens_goods_form"/>
    <field name="arch" type="xml">
      <xpath expr="//field[@name='product_id']" position="after">
        <field name="customs_description" />
      </xpath>
    </field>
  </record>
</odoo>