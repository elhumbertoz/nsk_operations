<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--
        REQ-016 a REQ-018: Vistas actualizadas para Régimen 70
        Este archivo agrega campos y tabs específicos para Régimen 70
    -->

    <!-- Inherit form view to add Régimen 70 fields -->
    <record id="view_ek_operation_request_regime_70_form" model="ir.ui.view">
        <field name="name">ek.operation.request.regime.70.form</field>
        <field name="model">ek.operation.request</field>
        <field name="inherit_id" ref="ek_l10n_shipping_operations.ek_operation_request_form"/>
        <field name="arch" type="xml">

            <!-- Botones de notificación en el header (Régimen 70) -->
            <xpath expr="//header" position="inside">
                <field name="regime" invisible="1"/>
                <field name="shipping_agent_id" invisible="1"/>
                <field name="res_partner_id" invisible="1"/>
                <field name="transfer_explanation" invisible="1"/>
                <field name="number_mrn" invisible="1"/>
                <field name="stage_sequence" invisible="1"/>
                <field name="stage_fold" invisible="1"/>
                <field name="mail_sent_customs_agent" invisible="1"/>
                <field name="mail_sent_warehouse" invisible="1"/>
                <field name="mail_sent_driver_info" invisible="1"/>
                <field name="mail_sent_custody" invisible="1"/>
                <field name="mail_sent_insurance" invisible="1"/>
                <button name="action_send_mail_customs_agent"
                        string="NotificarAgente Aduanas"
                        type="object"
                        class="btn-secondary"
                        icon="fa-envelope"
                        invisible="regime not in ['70'] or stage_sequence &lt; 11 or stage_fold or mail_sent_customs_agent"/>
                <button name="action_send_mail_warehouse"
                        string="Notificar Almacenera"
                        type="object"
                        class="btn-secondary"
                        icon="fa-envelope"
                        invisible="regime not in ['70'] or stage_sequence &lt; 13 or stage_fold or mail_sent_warehouse"/>
                <button name="action_send_mail_driver_info"
                        string="Notificar Datos Chofer"
                        type="object"
                        class="btn-secondary"
                        icon="fa-truck"
                        invisible="regime not in ['70'] or stage_sequence &lt; 22 or stage_fold or mail_sent_driver_info"/>
                <button name="action_send_mail_custody"
                        string="Notificar Custodia"
                        type="object"
                        class="btn-warning"
                        icon="fa-shield"
                        invisible="regime not in ['70'] or stage_sequence &lt; 22 or stage_fold or mail_sent_custody"/>
                <button name="action_send_mail_insurance"
                        string="Notificar Póliza"
                        type="object"
                        class="btn-secondary"
                        icon="fa-file-text"
                        invisible="regime not in ['70'] or stage_sequence &lt; 22 or stage_fold or mail_sent_insurance"/>
            </xpath>

            <!-- REQ-017: Cambiar label ID BL → ID CONTENEDOR -->
            <xpath expr="//field[@name='id_bl']" position="before">
                <label for="id_bl" string="ID CONTENEDOR" invisible="not regime in ['70']"/>
            </xpath>

            <!-- Agregar campos de Régimen 70 en grupo principal
                 NOTA: authorization_code, shipping_lines, date_transfer y
                 date_return_container vienen dinámicamente del Tipo de Solicitud -->
            <xpath expr="//field[@name='ek_group_mail_template_id']" position="after">
                <field name="regime" invisible="1"/>

                <field name="client_partner_id"
                       invisible="not regime in ['70']"
                       options="{'no_create': True}"/>

                <field name="client_vessel_name"
                       invisible="not regime in ['70']"
                       placeholder="Nombre del barco del cliente"/>
            </xpath>

            <!-- Agregar tabs nuevos al notebook -->
            <xpath expr="//form[1]/sheet[1]/notebook[1]" position="inside">

                <page string="Régimen 70" invisible="not regime in ['70']">

                    <!-- SECCIÓN: Notificaciones y Seguimiento -->

                    <!-- SECCIÓN: Estado de Notificaciones -->
                    <group string="📊 Estado de Notificaciones Enviadas">
                        <group>
                            <field name="mail_sent_customs_agent" widget="boolean_toggle" readonly="1"/>
                            <field name="mail_sent_customs_agent_date" readonly="1" invisible="not mail_sent_customs_agent"/>
                            <field name="mail_sent_warehouse" widget="boolean_toggle" readonly="1"/>
                            <field name="mail_sent_warehouse_date" readonly="1" invisible="not mail_sent_warehouse"/>
                            <field name="mail_sent_driver_info" widget="boolean_toggle" readonly="1"/>
                            <field name="mail_sent_driver_info_date" readonly="1" invisible="not mail_sent_driver_info"/>
                        </group>
                        <group>
                            <field name="mail_sent_custody" widget="boolean_toggle" readonly="1"/>
                            <field name="mail_sent_custody_date" readonly="1" invisible="not mail_sent_custody"/>
                            <field name="mail_sent_insurance" widget="boolean_toggle" readonly="1"/>
                            <field name="mail_sent_insurance_date" readonly="1" invisible="not mail_sent_insurance"/>
                        </group>
                    </group>

                    <!-- SECCIÓN: Plantillas Configurables -->
                    <group string="⚙️ Plantillas de Correo Configurables">
                        <group>
                            <field name="mail_template_customs_agent"
                                   options="{'no_create': True}"
                                   help="Plantilla para solicitud al agente de aduanas"/>
                            <field name="mail_template_warehouse"
                                   options="{'no_create': True}"
                                   help="Plantilla para solicitud a almacenera"/>
                            <field name="mail_template_driver_info"
                                   options="{'no_create': True}"
                                   help="Plantilla para datos de chofer"/>
                        </group>
                        <group>
                            <field name="mail_template_custody"
                                   options="{'no_create': True}"
                                   help="Plantilla para solicitud de custodia"/>
                            <field name="mail_template_insurance"
                                   options="{'no_create': True}"
                                   help="Plantilla para aplicación de póliza"/>
                        </group>
                    </group>

                    <separator/>

                    <group string="Documentación y Autorizaciones">
                        <group>
                            <field name="number_bl" string="Número BL"/>
                            <field name="booking_number"/>
                            <field name="seal_number"/>
                            <field name="authorization_code" string="# Autorización"/>
                            <field name="deposit_description" placeholder="MA-00"/>
                            <field name="dae_regularized"/>
                            <field name="days_in_deposit" readonly="1"/>
                        </group>
                        <group>
                            <field name="shipping_lines" string="Línea Naviera"/>
                            <field name="consignee_id" options="{'no_create': True}"/>
                            <field name="on_board_date"/>
                            <field name="type_move_fcl_lcl"/>
                            <field name="detail_supplies_spare_parts" string="Detalle"/>
                        </group>
                    </group>
<!-- 
                    <group string="Póliza de Transporte">
                        <group>
                            <field name="insurance_contract_date"/>
                        </group>
                        <group>
                            <field name="insurance_renewal_from"/>
                            <field name="insurance_renewal_to"/>
                        </group>
                    </group> -->


                    <group string="Ruta de Custodia">
                        <group>
                            <field name="custody_origin"/>
                        </group>
                        <group>
                            <field name="custody_destination"/>
                        </group>
                    </group>

                    <group string="Orden de Venta">
                        <field name="sale_order_id" readonly="1"/>
                        <button name="action_generate_sale_order"
                                string="Generar Orden de Venta"
                                type="object"
                                class="btn-primary"
                                icon="fa-file-text-o"
                                invisible="sale_order_id or not client_partner_id"/>
                    </group>

                    <group string="Resumen de Bultos por Buque" invisible="not total_packages_by_vessel">
                        <field name="total_packages_count" readonly="1"/>
                        <field name="total_packages_by_vessel"
                               widget="text"
                               readonly="1"
                               nolabel="1"/>
                    </group>
                </page>


            </xpath>

            <!-- Corregir y completar el árbol de productos en Solicitudes (ek.operation.request) -->
            <xpath expr="//field[@name='ek_produc_packages_goods_ids']" position="before">
                <button name="action_open_goods_management"
                        type="object"
                        string="Gestionar Mercancías (Vista Completa)"
                        class="btn btn-primary mb-2"
                        icon="fa-arrows-alt"
                        invisible="not regime in ['70']"/>
            </xpath>

            <xpath expr="//field[@name='ek_produc_packages_goods_ids']//tree" position="attributes">
                <attribute name="editable">bottom</attribute>
            </xpath>

            <xpath expr="//field[@name='ek_produc_packages_goods_ids']//tree/field[@name='ek_requerid_burden_inter_nac_id']" position="attributes">
                <attribute name="required">0</attribute>
                <attribute name="optional">hide</attribute>
            </xpath>

            <xpath expr="//field[@name='ek_produc_packages_goods_ids']//tree/field[1]" position="before">
                <field name="sequence" widget="handle"/>
            </xpath>

            <xpath expr="//field[@name='ek_produc_packages_goods_ids']//tree/field[@name='name']" position="before">
                <field name="product_id"
                       domain="[('categ_id', '=', %(ek_l10n_shipping_operations_charging_regimes.product_category_regime_70)d)]"
                       options="{'no_create': True}"
                       invisible="not parent.regime in ['70']"/>
                <field name="extracted_name"
                       string="Descripción Proveedor"
                       optional="hide"
                       invisible="not parent.regime in ['70']"/>
            </xpath>

            <xpath expr="//field[@name='ek_produc_packages_goods_ids']//tree/field[@name='quantity']" position="after">
                <field name="uom_id" optional="show" invisible="not parent.regime in ['70']"/>
                <field name="fob" invisible="not parent.regime in ['70']"/>
                <field name="total_fob" sum="Total FOB" invisible="not parent.regime in ['70']"/>
                <field name="invoice_number" optional="show" invisible="not parent.regime in ['70']"/>
                <field name="supplier" optional="show" invisible="not parent.regime in ['70']"/>
                <field name="ship_id" string="Buque Destino" optional="show" invisible="not parent.regime in ['70']"/>
                <field name="packages_count" string="Bultos" optional="show" invisible="not parent.regime in ['70']"/>
                <field name="commercial_unit" optional="hide" invisible="not parent.regime in ['70']"/>
                <field name="observation" optional="hide" invisible="not parent.regime in ['70']"/>
            </xpath>

        </field>
    </record>

    <!-- REQ-018: Search view with filter by vessel -->
    <record id="view_ek_operation_request_search_regime_70" model="ir.ui.view">
        <field name="name">ek.operation.request.search.regime.70</field>
        <field name="model">ek.operation.request</field>
        <field name="inherit_id" ref="ek_l10n_shipping_operations.ek_operation_request_search"/>
        <field name="arch" type="xml">
            <xpath expr="//search" position="inside">
                <filter string="Régimen 70"
                        name="filter_regime_70"
                        domain="[('regime', '=', '70')]"/>


                <filter string="Con Orden de Venta"
                        name="filter_with_so"
                        domain="[('sale_order_id', '!=', False), ('regime', '=', '70')]"/>

                <group expand="0" string="Agrupar Por">
                    <filter string="Cliente"
                            name="group_by_client"
                            context="{'group_by': 'client_partner_id'}"/>
                    <filter string="Línea Naviera"
                            name="group_by_shipping_line"
                            context="{'group_by': 'shipping_lines'}"/>
                </group>
            </xpath>
        </field>
    </record>

    <!-- Vista de partner para agregar campo markup -->
    <record id="view_res_partner_form_maritime_markup" model="ir.ui.view">
        <field name="name">res.partner.form.maritime.markup</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='sales_purchases']" position="inside">
                <group string="Servicios Marítimos" invisible="not is_company">
                    <field name="maritime_service_markup"/>
                </group>
            </xpath>
        </field>
    </record>

</odoo>
