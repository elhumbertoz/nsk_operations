<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <!-- model.name inherit form view -->
  <record id="ek_ship_registration_form" model="ir.ui.view">
    <field name="name">ek.ship.registration.form</field>
    <field name="model">ek.ship.registration</field>
    <field name="inherit_id" ref="ek_l10n_shipping_operations.ek_ship_registration_form"/>
    <field name="arch" type="xml">
      <!-- Add your xpath here -->
      <xpath expr="//button[@name='action_open_documents_travel']" position="attributes">
        <attribute name="invisible">assigned_regimen_70</attribute>
      </xpath>
      <xpath expr="//button[@name='action_open_documents_trip_details_days']" position="attributes">
        <attribute name="invisible">assigned_regimen_70</attribute>
      </xpath>
      <xpath expr="//button[@name='action_open_ship_document_certificate_count']" position="attributes">
        <attribute name="invisible">assigned_regimen_70</attribute>
      </xpath>

      <xpath expr="//button[@name='action_open_documents_travel']" position="after">
        <button class="oe_stat_button" name="action_open_documents_container" type="object" icon="fa-truck" invisible="not assigned_regimen_70">
          <field string="Contenedores" name="travel_count" widget="statinfo" invisible="not assigned_regimen_70"/>
        </button>
      </xpath>

    </field>
  </record>
</odoo>