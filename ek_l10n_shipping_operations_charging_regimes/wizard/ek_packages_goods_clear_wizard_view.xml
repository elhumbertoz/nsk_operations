<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <record id="ek_packages_goods_clear_wizard_form" model="ir.ui.view">
    <field name="name">ek.packages.goods.clear.wizard.form</field>
    <field name="model">ek.packages.goods.clear.wizard</field>
    <field name="arch" type="xml">
      <form string="Confirmar eliminación de paquetes y mercancías">
        <div class="alert alert-warning mb-0" role="alert">
          <div style="display: flex; align-items: center; color: white;">
            <i class="fa fa-exclamation-triangle d-flex align-items-center" style="color: #f39c12; font-size: 16px; margin-right: 10px;"></i>
            <strong>¡ADVERTENCIA!</strong>
          </div>
          <div style="width: 100%; height: 7px;"></div>
          <p class="mb-0">
            Está a punto de eliminar <strong>
            <field name="total_records" readonly="1" style="display: inline; background: none; border: none; font-weight: bold;"/>
            registro(s). Esta acción no se puede deshacer.</strong>
        </p>
      </div>

      <field name="operation_request_ids" invisible="1"/>
      <field name="warning_message" invisible="1"/>

      <footer>
        <div class="d-flex gap-1" style="width: 400px;">
          <button string="Sí, eliminar datos" name="action_confirm_clear" type="object" class="btn btn-danger"/>
          <button string="Cancelar" name="action_cancel" type="object" class="btn btn-secondary" special="cancel"/>
        </div>
      </footer>
    </form>
  </field>
</record>
</odoo> 