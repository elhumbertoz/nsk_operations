<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="ek_wizard_charging_data_form" model="ir.ui.view">
        <field name="name">ek.wizard.charging.data.tree</field>
        <field name="model">ek.wizard.charging.data</field>
        <field name="arch" type="xml">
            <tree string="Kardex Régimen 70 / 60"
                  decoration-info="regimen == '70'"
                  decoration-warning="regimen == '60'">
                <field name="boats_information_id"/>
                <field name="movement_date" widget="date"/>
                <field name="regimen"/>
                <field name="related_document"/>
                <field name="tariff_item"/>
                <field name="product_description"/>
                <field name="max_regime_date" widget="date" optional="hide"/>
                <field name="unds_in" sum="Total Entradas"/>
                <field name="unds_out" sum="Total Salidas"/>
                <field name="balance"/>
                <field name="unit_cost" optional="show"/>
                <field name="total_cost" sum="Total FOB" optional="show"/>
                <field name="customs_document" optional="show"/>
                <field name="ship_registration_id" optional="hide"/>
                <field name="date_request" widget="date" optional="hide"/>
            </tree>
        </field>
    </record>
</odoo>
