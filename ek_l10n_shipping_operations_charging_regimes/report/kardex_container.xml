<?xml version='1.0' encoding='UTF-8'?>
<odoo>
    <record id="paperformat_kardex_shipping" model="report.paperformat">
        <field name="name">A4</field>
        <field name="default" eval="True"/>
        <field name="format">A4</field>
        <field name="page_height">0</field>
        <field name="page_width">0</field>
        <field name="orientation">Landscape</field>
        <field name="margin_top">25</field>
        <field name="margin_bottom">12</field>
        <field name="margin_left">11</field>
        <field name="margin_right">11</field>
        <field name="header_line" eval="False"/>
        <field name="header_spacing">0</field>
        <field name="dpi">90</field>
    </record>
    <record id="report_action_kardex_container" model="ir.actions.report">
        <field name="name">Reporte Kardex container</field>

        <field name="model">ek.boats.information</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">ek_l10n_shipping_operations_charging_regimes.report_template_kardex_container</field>
        <field name="report_file">ek_l10n_shipping_operations_charging_regimes.report_template_kardex_container</field>
        <field name="paperformat_id" ref="ek_l10n_shipping_operations_charging_regimes.paperformat_kardex_shipping"/>
    </record>


    <template id="report_template_kardex_container">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="web.basic_layout">
                    <div class="page">
                        <h1 class="text-center">
                            <strong>Kardex
                                <span t-field="o.name"/>
                            </strong>
                        </h1>
                    </div>
                    <div>
                        <h5 class="text-left">
                            <u>Datos</u>
                        </h5>
                    </div>

                    <br/>
                    <div class="container-fluid">
                        <table class="table-bordered" order="1" style="float: left;" width="100%">
                            <thead>
                                <tr>
                                    <th class="text-center">H02. Subpartida</th>
                                    <th class="text-center">Código complementario</th>
                                    <th class="text-center">H04. Codigo suplementario</th>
                                    <th class="text-center">H06. Descripcion</th>
                                    <th class="text-center">H10. Peso neto</th>
                                    <th class="text-center">H18. Cantidad de unidades fisicas</th>
                                    <th class="text-center">H19. Tipo de unidad comercial</th>
                                    <th class="text-center">H26. FOB unitario</th>
                                    <th class="text-center">Total de FOB</th>
                                    <th class="text-center">H34. Numero de factura</th>
                                    <th class="text-center">H35. Nombre/razon social del proveedor</th>
                                    <th class="text-center">BL</th>



                                </tr>
                            </thead>
                            <tbody class="invoice_tbody">
                                <t t-foreach="o.ek_produc_packages_goods_ids" t-as="l">
                                    <t>
                                        <tr>
                                            <td class="text-center">
                                                <span t-field="l.tariff_item"/>
                                            </td>
                                            <td class="text-center">
                                                <span t-field="l.id_hs_copmt_cd"/>
                                            </td>
                                            <td class="text-center">
                                                <span t-field="l.id_hs_spmt_cd"/>
                                            </td>
                                            <td class="text-center">
                                                <span t-field="l.ek_requerid_burden_inter_nac_id.name"/>
                                            </td>

                                            <td class="text-center">
                                                <span t-field="l.gross_weight"/>
                                            </td>
                                            <td class="text-center">
                                                <span t-field="l.quantity"/>
                                            </td>
                                            <td class="text-center">
                                                <span t-field="l.uom_id.name"/>
                                            </td>
                                            <td class="text-center">
                                                <span t-field="l.fob"/>
                                            </td>

                                            <td class="text-center">
                                                <span t-field="l.total_fob"/>
                                            </td>


                                            <td class="text-center">
                                                <span t-field="l.invoice_number"/>
                                            </td>
                                            <td class="text-center">
                                                <span t-field="l.supplier"/>
                                            </td>
                                            <td class="text-center">
                                                <span t-field="l.id_bl.name"/>
                                            </td>
                                        </tr>
                                    </t>
                                </t>
                            </tbody>
                        </table>
                    </div>


                </t>
            </t>
        </t>
    </template>

    <!-- ═══ KARDEX 70/60 - Reporte sobre ek.wizard.charging.data ═══ -->
    <record id="action_report_kardex_70_60" model="ir.actions.report">
        <field name="name">Kardex Régimen 70 / 60</field>
        <field name="model">ek.wizard.charging.data</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">ek_l10n_shipping_operations_charging_regimes.report_template_kardex_70_60</field>
        <field name="report_file">ek_l10n_shipping_operations_charging_regimes.report_template_kardex_70_60</field>
        <field name="paperformat_id" ref="ek_l10n_shipping_operations_charging_regimes.paperformat_kardex_shipping"/>
    </record>

    <template id="report_template_kardex_70_60">
        <t t-call="web.html_container">
            <t t-call="web.basic_layout">
                <div class="page">
                    <h4 class="text-center" style="margin-bottom:12px;">
                        <strong>KARDEX RÉGIMEN 70 / 60</strong>
                    </h4>

                    <table class="table table-sm" style="font-size:8px; width:100%; border-collapse:collapse;">
                        <thead>
                            <tr style="background-color:#1F4E79; color:white; text-align:center;">
                                <th style="border:1px solid #ccc; padding:3px;">Fecha Mov.</th>
                                <th style="border:1px solid #ccc; padding:3px;">Rég.</th>
                                <th style="border:1px solid #ccc; padding:3px;">BL</th>
                                <th style="border:1px solid #ccc; padding:3px;">Subpartida</th>
                                <th style="border:1px solid #ccc; padding:3px;">Descripción</th>
                                <th style="border:1px solid #ccc; padding:3px;">F.Max Rég.</th>
                                <th style="border:1px solid #ccc; padding:3px; text-align:right;">Entrada</th>
                                <th style="border:1px solid #ccc; padding:3px; text-align:right;">Salida</th>
                                <th style="border:1px solid #ccc; padding:3px; text-align:right;">Saldo</th>
                                <th style="border:1px solid #ccc; padding:3px; text-align:right;">FOB Unit.</th>
                                <th style="border:1px solid #ccc; padding:3px; text-align:right;">Total FOB</th>
                                <th style="border:1px solid #ccc; padding:3px;">Doc. Aduana</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-set="total_in" t-value="0"/>
                            <t t-set="total_out" t-value="0"/>
                            <t t-set="total_fob" t-value="0"/>
                            <t t-set="current_container" t-value="0"/>
                            <t t-foreach="docs" t-as="line">
                                <t t-if="line.boats_information_id.id != current_container">
                                    <tr style="background-color:#404040; color:white; font-weight:bold;">
                                        <td colspan="12" style="padding:4px;">
                                            <span>CONTENEDOR: </span>
                                            <t t-out="line.boats_information_id.name or 'Sin contenedor'"/>
                                            <t t-if="line.ship_registration_id">
                                                <span>   |   BUQUE: </span>
                                                <t t-out="line.ship_registration_id.name or ''"/>
                                            </t>
                                        </td>
                                    </tr>
                                    <t t-set="current_container" t-value="line.boats_information_id.id"/>
                                </t>

                                <t t-set="row_color" t-value="'#FCE4D6' if line.regimen == '60' else '#DEEAF1'"/>
                                <tr t-attf-style="background-color:#{row_color};">
                                    <td style="border:1px solid #ccc; padding:2px; text-align:center;">
                                        <t t-if="line.movement_date">
                                            <span t-field="line.movement_date" t-options='{"widget": "date"}'/>
                                        </t>
                                    </td>
                                    <td style="border:1px solid #ccc; padding:2px; text-align:center; font-weight:bold;">
                                        <t t-out="line.regimen or ''"/>
                                    </td>
                                    <td style="border:1px solid #ccc; padding:2px;">
                                        <t t-out="line.related_document.name or ''"/>
                                    </td>
                                    <td style="border:1px solid #ccc; padding:2px;">
                                        <t t-out="line.tariff_item or ''"/>
                                    </td>
                                    <td style="border:1px solid #ccc; padding:2px;">
                                        <t t-out="line.product_description.name or ''"/>
                                    </td>
                                    <td style="border:1px solid #ccc; padding:2px; text-align:center;">
                                        <t t-if="line.max_regime_date">
                                            <span t-field="line.max_regime_date" t-options='{"widget": "date"}'/>
                                        </t>
                                    </td>
                                    <td style="border:1px solid #ccc; padding:2px; text-align:right;">
                                        <t t-if="line.unds_in">
                                            <t t-out="'%.2f' % line.unds_in"/>
                                        </t>
                                    </td>
                                    <td style="border:1px solid #ccc; padding:2px; text-align:right;">
                                        <t t-if="line.unds_out">
                                            <t t-out="'%.2f' % line.unds_out"/>
                                        </t>
                                    </td>
                                    <td style="border:1px solid #ccc; padding:2px; text-align:right; font-weight:bold;">
                                        <t t-out="'%.2f' % (line.balance or 0)"/>
                                    </td>
                                    <td style="border:1px solid #ccc; padding:2px; text-align:right;">
                                        <t t-out="'%.2f' % (line.unit_cost or 0)"/>
                                    </td>
                                    <td style="border:1px solid #ccc; padding:2px; text-align:right;">
                                        <t t-out="'%.2f' % (line.total_cost or 0)"/>
                                    </td>
                                    <td style="border:1px solid #ccc; padding:2px;">
                                        <t t-out="line.customs_document or ''"/>
                                    </td>
                                </tr>
                                <t t-set="total_in" t-value="total_in + (line.unds_in or 0)"/>
                                <t t-set="total_out" t-value="total_out + (line.unds_out or 0)"/>
                                <t t-set="total_fob" t-value="total_fob + (line.total_cost or 0)"/>
                            </t>
                        </tbody>
                        <tfoot>
                            <tr style="background-color:#1F4E79; color:white; font-weight:bold;">
                                <td colspan="6" style="border:1px solid #ccc; padding:3px; text-align:right;">TOTALES GENERALES</td>
                                <td style="border:1px solid #ccc; padding:3px; text-align:right;">
                                    <t t-out="'%.2f' % total_in"/>
                                </td>
                                <td style="border:1px solid #ccc; padding:3px; text-align:right;">
                                    <t t-out="'%.2f' % total_out"/>
                                </td>
                                <td style="border:1px solid #ccc; padding:3px;"/>
                                <td style="border:1px solid #ccc; padding:3px;"/>
                                <td style="border:1px solid #ccc; padding:3px; text-align:right;">
                                    <t t-out="'%.2f' % total_fob"/>
                                </td>
                                <td style="border:1px solid #ccc; padding:3px;"/>
                            </tr>
                        </tfoot>
                    </table>

                    <div style="margin-top:10px; font-size:8px;">
                        <span style="background-color:#DEEAF1; padding:2px 6px; margin-right:8px;">Régimen 70 (Entradas)</span>
                        <span style="background-color:#FCE4D6; padding:2px 6px;">Régimen 60 (Salidas)</span>
                    </div>
                </div>
            </t>
        </t>
    </template>

</odoo>