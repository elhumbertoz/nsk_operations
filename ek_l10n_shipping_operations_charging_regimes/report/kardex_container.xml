<?xml version='1.0' encoding='UTF-8'?>
<odoo>
    <record id="paperformat_kardex_shipping" model="report.paperformat">
        <field name="name">A4</field>
        <field name="default" eval="True"/>
        <field name="format">A4</field>
        <field name="page_height">0</field>
        <field name="page_width">0</field>
        <field name="orientation">Landscape</field>
        <field name="margin_top">25</field>
        <field name="margin_bottom">12</field>
        <field name="margin_left">11</field>
        <field name="margin_right">11</field>
        <field name="header_line" eval="False"/>
        <field name="header_spacing">0</field>
        <field name="dpi">90</field>
    </record>
    <record id="report_action_kardex_container" model="ir.actions.report">
        <field name="name">Reporte Kardex container</field>

        <field name="model">ek.boats.information</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">ek_l10n_shipping_operations_charging_regimes.report_template_kardex_container</field>
        <field name="report_file">ek_l10n_shipping_operations_charging_regimes.report_template_kardex_container</field>
        <field name="paperformat_id" ref="ek_l10n_shipping_operations_charging_regimes.paperformat_kardex_shipping"/>
    </record>


    <template id="report_template_kardex_container">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="web.basic_layout">
                    <div class="page">
                        <h1 class="text-center">
                            <strong>Kardex
                                <span t-field="o.name"/>
                            </strong>
                        </h1>
                    </div>
                    <div>
                        <h5 class="text-left">
                            <u>Datos</u>
                        </h5>
                    </div>

                    <br/>
                    <div class="container-fluid">
                        <table class="table-bordered" order="1" style="float: left;" width="100%">
                            <thead>
                                <tr>
                                    <th class="text-center">H02. Subpartida</th>
                                    <th class="text-center">Código complementario</th>
                                    <th class="text-center">H04. Codigo suplementario</th>
                                    <th class="text-center">H06. Descripcion</th>
                                    <th class="text-center">H10. Peso neto</th>
                                    <th class="text-center">H18. Cantidad de unidades fisicas</th>
                                    <th class="text-center">H19. Tipo de unidad comercial</th>
                                    <th class="text-center">H26. FOB unitario</th>
                                    <th class="text-center">Total de FOB</th>
                                    <th class="text-center">H34. Numero de factura</th>
                                    <th class="text-center">H35. Nombre/razon social del proveedor</th>
                                    <th class="text-center">BL</th>



                                </tr>
                            </thead>
                            <tbody class="invoice_tbody">
                                <t t-foreach="o.ek_produc_packages_goods_ids" t-as="l">
                                    <t>
                                        <tr>
                                            <td class="text-center">
                                                <span t-field="l.tariff_item"/>
                                            </td>
                                            <td class="text-center">
                                                <span t-field="l.id_hs_copmt_cd"/>
                                            </td>
                                            <td class="text-center">
                                                <span t-field="l.id_hs_spmt_cd"/>
                                            </td>
                                            <td class="text-center">
                                                <span t-field="l.ek_requerid_burden_inter_nac_id.name"/>
                                            </td>

                                            <td class="text-center">
                                                <span t-field="l.gross_weight"/>
                                            </td>
                                            <td class="text-center">
                                                <span t-field="l.quantity"/>
                                            </td>
                                            <td class="text-center">
                                                <span t-field="l.uom_id.name"/>
                                            </td>
                                            <td class="text-center">
                                                <span t-field="l.fob"/>
                                            </td>

                                            <td class="text-center">
                                                <span t-field="l.total_fob"/>
                                            </td>


                                            <td class="text-center">
                                                <span t-field="l.invoice_number"/>
                                            </td>
                                            <td class="text-center">
                                                <span t-field="l.supplier"/>
                                            </td>
                                            <td class="text-center">
                                                <span t-field="l.id_bl.name"/>
                                            </td>
                                        </tr>
                                    </t>
                                </t>
                            </tbody>
                        </table>
                    </div>


                </t>
            </t>
        </t>
    </template>

    <!-- ═══ KARDEX 70/60 - Reporte sobre ek.wizard.charging.data ═══ -->
    <record id="action_report_kardex_70_60" model="ir.actions.report">
        <field name="name">Kárdex Régimen 70 / 60</field>
        <field name="model">ek.product.packagens.goods</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">ek_l10n_shipping_operations_charging_regimes.report_template_kardex_70_60</field>
        <field name="report_file">ek_l10n_shipping_operations_charging_regimes.report_template_kardex_70_60</field>
        <field name="paperformat_id" ref="ek_l10n_shipping_operations_charging_regimes.paperformat_kardex_shipping"/>
    </record>

    <template id="report_template_kardex_70_60">
        <t t-call="web.html_container">
            <t t-call="web.basic_layout">
                <div class="page">
                    <div class="text-center" style="margin-bottom:10px;">
                        <h3 style="margin:0; color:#1F4E79;">
                            <strong>KÁRDEX INVENTARIO RÉGIMEN 70 / 60</strong>
                        </h3>
                        <div style="font-size:10px; color:#555;">
                            <span t-out="res_company.name"/>
                            <t t-if="context.get('kardex_period_from') or context.get('kardex_period_to')">
                                &#xa0;·&#xa0;Período:
                                <t t-out="context.get('kardex_period_from') or '—'"/> →
                                <t t-out="context.get('kardex_period_to') or '—'"/>
                            </t>
                        </div>
                    </div>

                    <table class="table table-sm" style="font-size:7.5px; width:100%; border-collapse:collapse;">
                        <thead>
                            <tr style="background-color:#1F4E79; color:white; text-align:center;">
                                <th style="border:1px solid #ccc; padding:3px;">Carga</th>
                                <th style="border:1px solid #ccc; padding:3px;">Sol. Previa</th>
                                <th style="border:1px solid #ccc; padding:3px;">BL</th>
                                <th style="border:1px solid #ccc; padding:3px;">Contenedor</th>
                                <th style="border:1px solid #ccc; padding:3px;">DAI</th>
                                <th style="border:1px solid #ccc; padding:3px;">Buque</th>
                                <th style="border:1px solid #ccc; padding:3px;">Detalle</th>
                                <th style="border:1px solid #ccc; padding:3px; text-align:right;">Cant.</th>
                                <th style="border:1px solid #ccc; padding:3px; text-align:right;">Entreg.</th>
                                <th style="border:1px solid #ccc; padding:3px; text-align:right;">Saldo</th>
                                <th style="border:1px solid #ccc; padding:3px;">F. Ingreso</th>
                                <th style="border:1px solid #ccc; padding:3px;">F. Vto.</th>
                                <th style="border:1px solid #ccc; padding:3px;">Días</th>
                                <th style="border:1px solid #ccc; padding:3px;">Estado</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-set="total_qty" t-value="0"/>
                            <t t-set="total_delivered" t-value="0"/>
                            <t t-set="total_saldo" t-value="0"/>
                            <t t-set="current_request" t-value="0"/>
                            <t t-foreach="docs" t-as="item">
                                <t t-if="item.ek_operation_request_id.id != current_request">
                                    <tr style="background-color:#404040; color:white; font-weight:bold;">
                                        <td colspan="14" style="padding:4px;">
                                            <span>TRÁMITE: </span>
                                            <t t-out="item.ek_operation_request_id.name or 'Sin trámite'"/>
                                            <t t-if="item.kardex_referencia">
                                                <span>   ·   </span>
                                                <t t-out="item.kardex_referencia"/>
                                            </t>
                                            <t t-if="item.kardex_ship_display">
                                                <span>   ·   BUQUE: </span>
                                                <t t-out="item.kardex_ship_display.name or ''"/>
                                            </t>
                                        </td>
                                    </tr>
                                    <t t-set="current_request" t-value="item.ek_operation_request_id.id"/>
                                </t>

                                <t t-set="row_bg"
                                   t-value="'#C6EFCE' if item.state_kardex == 'delivered' else ('#FFEB9C' if item.state_kardex == 'partial' else ('#FFC7CE' if item.state_kardex == 'expired' else '#DEEAF1'))"/>
                                <tr t-attf-style="background-color:#{row_bg};">
                                    <td style="border:1px solid #ccc; padding:2px;">
                                        <t t-out="item.ek_operation_request_id.name or ''"/>
                                    </td>
                                    <td style="border:1px solid #ccc; padding:2px; text-align:center;">
                                        <t t-out="item.kardex_solicitud_previa or ''"/>
                                    </td>
                                    <td style="border:1px solid #ccc; padding:2px;">
                                        <t t-out="item.kardex_bl_display or ''"/>
                                    </td>
                                    <td style="border:1px solid #ccc; padding:2px;">
                                        <t t-out="item.kardex_container_display.name if item.kardex_container_display else ''"/>
                                    </td>
                                    <td style="border:1px solid #ccc; padding:2px;">
                                        <t t-out="item.number_dai or ''"/>
                                    </td>
                                    <td style="border:1px solid #ccc; padding:2px;">
                                        <t t-out="item.kardex_ship_display.name if item.kardex_ship_display else ''"/>
                                    </td>
                                    <td style="border:1px solid #ccc; padding:2px;">
                                        <t t-out="item.name or ''"/>
                                    </td>
                                    <td style="border:1px solid #ccc; padding:2px; text-align:right;">
                                        <t t-out="'%.2f' % (item.quantity or 0)"/>
                                    </td>
                                    <td style="border:1px solid #ccc; padding:2px; text-align:right;">
                                        <t t-out="'%.2f' % (item.total_delivered_reg60 or 0)"/>
                                    </td>
                                    <td style="border:1px solid #ccc; padding:2px; text-align:right; font-weight:bold;">
                                        <t t-out="'%.2f' % (item.balance_kardex or 0)"/>
                                    </td>
                                    <td style="border:1px solid #ccc; padding:2px; text-align:center;">
                                        <t t-if="item.kardex_fecha_ingreso">
                                            <span t-field="item.kardex_fecha_ingreso" t-options='{"widget": "date"}'/>
                                        </t>
                                    </td>
                                    <td style="border:1px solid #ccc; padding:2px; text-align:center;">
                                        <t t-if="item.max_regime_date">
                                            <span t-field="item.max_regime_date" t-options='{"widget": "date"}'/>
                                        </t>
                                    </td>
                                    <td style="border:1px solid #ccc; padding:2px; text-align:center;">
                                        <t t-out="item.days_to_expiry or 0"/>
                                    </td>
                                    <td style="border:1px solid #ccc; padding:2px; text-align:center; font-weight:bold;">
                                        <t t-if="item.state_kardex == 'delivered'">REEXPORTADO</t>
                                        <t t-elif="item.state_kardex == 'partial'">PARCIAL</t>
                                        <t t-elif="item.state_kardex == 'expired'">VENCIDO</t>
                                        <t t-elif="item.state_kardex == 'stock'">EN STOCK</t>
                                    </td>
                                </tr>
                                <t t-set="total_qty" t-value="total_qty + (item.quantity or 0)"/>
                                <t t-set="total_delivered" t-value="total_delivered + (item.total_delivered_reg60 or 0)"/>
                                <t t-set="total_saldo" t-value="total_saldo + (item.balance_kardex or 0)"/>
                            </t>
                        </tbody>
                        <tfoot>
                            <tr style="background-color:#1F4E79; color:white; font-weight:bold;">
                                <td colspan="7" style="border:1px solid #ccc; padding:3px; text-align:right;">TOTALES GENERALES</td>
                                <td style="border:1px solid #ccc; padding:3px; text-align:right;">
                                    <t t-out="'%.2f' % total_qty"/>
                                </td>
                                <td style="border:1px solid #ccc; padding:3px; text-align:right;">
                                    <t t-out="'%.2f' % total_delivered"/>
                                </td>
                                <td style="border:1px solid #ccc; padding:3px; text-align:right;">
                                    <t t-out="'%.2f' % total_saldo"/>
                                </td>
                                <td colspan="4" style="border:1px solid #ccc; padding:3px;"/>
                            </tr>
                        </tfoot>
                    </table>

                    <div style="margin-top:10px; font-size:8px; color:#555;">
                        <strong>Leyenda de Estados:</strong>
                        <span style="background-color:#DEEAF1; padding:1px 5px; margin:0 3px;">EN STOCK</span>
                        <span style="background-color:#FFEB9C; padding:1px 5px; margin:0 3px;">PARCIAL</span>
                        <span style="background-color:#C6EFCE; padding:1px 5px; margin:0 3px;">REEXPORTADO</span>
                        <span style="background-color:#FFC7CE; padding:1px 5px; margin:0 3px;">VENCIDO</span>
                    </div>
                </div>
            </t>
        </t>
    </template>


</odoo>