<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record model="ir.cron" id="cron_l10n_ec_withhold_pending">
            <field name='name'>Retenciones pendientes: Enviar correos a clientes por retenciones pendientes</field>
            <field name='interval_number'>1</field>
            <field name='interval_type'>days</field>
            <field name="numbercall">-1</field>
            <field name="active">True</field>
            <field name="doall" eval="False"/>
            <field name="model_id" ref="account.model_account_move"/>
            <field name="state">code</field>
            <field name="code">model.cron_send_email_for_withhold_pending()</field>
            <field name="nextcall" eval="(DateTime.now().replace(day=1,hour=13, minute=0)).strftime('%Y-%m-%d %H:%M:%S')"/>
        </record>
    </data>
</odoo>