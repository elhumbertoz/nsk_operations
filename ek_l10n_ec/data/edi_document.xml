<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <template id="common_reimbursument_template">
            <reembolsos t-if="is_invoice and move.l10n_latam_document_type_id.code in ['41','03']">
                    <reembolsoDetalle t-as="item" t-foreach="reembolsos">
                        <tipoIdentificacionProveedorReembolso t-out="item['tipoIdentificacionProveedorReembolso']"/>
                        <identificacionProveedorReembolso t-out="item['identificacionProveedorReembolso']"/>
                        <codPaisPagoProveedorReembolso t-out="item['codPaisPagoProveedorReembolso']"/>
                        <tipoProveedorReembolso t-out="item['tipoProveedorReembolso']"/>
                        <codDocReembolso t-out="item['codDocReembolso']"/>
                        <estabDocReembolso t-out="item['estabDocReembolso']"/>
                        <ptoEmiDocReembolso t-out="item['ptoEmiDocReembolso']"/>
                        <secuencialDocReembolso t-out="item['secuencialDocReembolso']"/>
                        <fechaEmisionDocReembolso t-out="strftime(item['fechaEmisionDocReembolso'])"/>
                        <numeroautorizacionDocReemb t-out="item['numeroautorizacionDocReemb']"/>
                        <detalleImpuestos>
                            <detalleImpuesto t-as="tax" t-foreach="item['detalleImpuestos']">
                                <codigo t-out="tax['codigo']"/>
                                <codigoPorcentaje t-out="tax['codigoPorcentaje']"/>
                                <tarifa t-out="tax['tarifa']"/>
                                <baseImponibleReembolso t-out="tax['baseImponibleReembolso']"/>
                                <impuestoReembolso t-out="tax['impuestoReembolso']"/>

                            </detalleImpuesto>
                        </detalleImpuestos>

                    </reembolsoDetalle>
            </reembolsos>
        </template>

        <template id="common_l10n_ec_taxinherit_template"
                  inherit_id="l10n_ec_edi.common_tax_info_template">
            <xpath expr="//codDoc" position="replace">
                <codDoc t-out="'07' if is_withhold else '01' if move.l10n_latam_document_type_id.code in ['41','03'] and is_invoice else move.l10n_latam_document_type_id.code"/>
            </xpath>
        </template>

        <template id="common_l10n_ec_infonherit_template"
                  inherit_id="l10n_ec_edi.common_info_template">
            <xpath expr="//totalDescuento" position="after">
                <codDocReembolso t-if="is_invoice and move.l10n_latam_document_type_id.code in ['41','03']"
                                 t-out="move.l10n_latam_document_type_id.code"/>
                <totalComprobantesReembolso t-if="is_invoice and move.l10n_latam_document_type_id.code in ['41','03']"
                                            t-out="format_num_2(totalComprobantesReembolso)"/>
                <totalBaseImponibleReembolso t-if="is_invoice and move.l10n_latam_document_type_id.code in ['41','03']"
                                             t-out="format_num_2(totalBaseImponibleReembolso)"/>
                <totalImpuestoReembolso t-if="is_invoice and move.l10n_latam_document_type_id.code in ['41','03']"
                                        t-out="format_num_2(totalImpuestoReembolso)"/>
            </xpath>
        </template>





        <template id="common_l10n_ec_invoice_iherit_template"
                  inherit_id="l10n_ec_edi.invoice_template">
            <xpath expr="//t[@t-call='l10n_ec_edi.common_details_info_template']" position="after">
                <t t-call="ek_l10n_ec.common_reimbursument_template"/>


            </xpath>
        </template>

