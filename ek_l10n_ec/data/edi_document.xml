        <template id="common_tax_lines_template" inherit_id="l10n_ec_edi.common_details_info_template">
            <xpath expr="//detalles/detalle/impuestos/impuesto" position="replace">                
                    <impuesto t-foreach="line_tax_details.values()" t-as="tax_data">
                        <t t-if="int(tax_data['code_percentage']) == 5">
                            <t t-call="l10n_ec_edi.common_tax_lines_template">
                                <t t-set="tarifa_pre_base" t-value="True"/>
                            </t>
                        </t>
                        <t t-else="">
                            <t t-call="l10n_ec_edi.common_tax_lines_template">
                                <t t-set="tarifa_pre_base" t-value="True"/>
                            </t>
                        </t>
                    </impuesto>
            </xpath>
            <xpath expr="//detalles/detalle/codigoPrincipal" position="after">
                <codigoAuxiliar t-if="product.l10n_ec_auxiliary_code and (is_invoice or is_liquidation)" t-out="product.l10n_ec_auxiliary_code"/>
            </xpath>
        </template>

        <template  id="common_info_template" inherit_id="l10n_ec_edi.common_info_template">
            <xpath expr="//totalConImpuestos/totalImpuesto" position="replace">
                <totalImpuesto t-as="tax_data" t-foreach="tax_totals.values()">
                    <t t-if="int(tax_data['code_percentage']) == 5">
                        <t t-call="l10n_ec_edi.common_tax_lines_template">
                            <t t-set="tarifa_post_base" t-value="True if is_invoice else False"/>
                        </t>
                    </t>
                    <t t-else="">
                        <t t-call="l10n_ec_edi.common_tax_lines_template">
                            <t t-set="tarifa_post_base" t-value="True if is_invoice else False"/>
                        </t>
                    </t>
                </totalImpuesto>
            </xpath>
<!--            <xpath expr="//moneda[@t-if='is_cnote']" position="replace">-->
