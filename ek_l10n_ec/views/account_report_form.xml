<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- Inherit Form View to Modify it -->
        <record id="account_report_form" model="ir.ui.view">
            <field name="name">account_report_form</field>
            <field name="model">account.report</field>
            <field name="inherit_id" ref="account_reports.account_report_form"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='filter_period_comparison']" position="after">
                    <!-- Add your fields or attributes here -->
                    <field name="show_user"/>
                    <field name="show_date"/>
                </xpath>

                <xpath expr="//page[@name='page_options']/group" position="inside">
                    <group string="Pie de Página" class="oe_edit_only">
                        <field name="show_footer"/>
                        <field name="show_general_manager" invisible="not show_footer"/>
                        <field name="show_auditor" invisible="not show_footer"/>
                        <field name="show_controller" invisible="not show_footer"/>
                        <field name="show_counter" invisible="not show_footer"/>
                    </group>
                </xpath>

            </field>
        </record>
    </data>
</odoo>
