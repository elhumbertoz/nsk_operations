<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_move_form_auth" model="ir.ui.view">
        <field name="name">account.move.form.auth</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="l10n_latam_invoice_document.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='l10n_latam_document_number']" position="after">
                <field name="l10n_ec_sri_cancellation_number" invisible="not l10n_ec_sri_cancellation_number"/>
                <field name="l10n_latam_document_sustento_required" invisible="1"/>
                <field name="l10n_latam_document_sustento"
                       domain="['|', ('account_ats_doc_ids', 'in', l10n_latam_document_type_id), ('account_ats_doc_ids', '=', False)]"
                       required="l10n_latam_document_sustento_required"
                       invisible="not l10n_latam_use_documents and not l10n_latam_document_sustento_required"
                />
            </xpath>
<!--            <xpath expr="//field[@name='ref']" position="after">-->
<!--                <field name="import_from_xml" class="oe_edit_only oe_inline"-->
<!--                       string="Importar XMl" widget="boolean_toggle"-->
<!--                       help="Permite subir la autorización y el número de documento desde un XML autorizado"-->
<!--                />-->
<!--                <button name="action_import_from_xml" type="object" icon="fa-cloud-upload"-->
<!--                        class="oe_stat_button oe_edit_only" string="Importar XML" invisible="not import_from_xml"-->
<!--                />-->
<!--                <newline/>-->
<!--            </xpath>-->
        </field>
    </record>

    <!-- Inherit Form View to Modify it -->
    <record id="view_move_demo_form" model="ir.ui.view">
        <field name="name">account.move</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="l10n_ec_edi.account_move_form_invoice_and_withhold_view"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='l10n_latam_document_number']" position="after">
                <field name="l10n_latam_document_auth_required" invisible="1"/>
            </xpath>
            <xpath expr="//field[@name='l10n_ec_authorization_number']" position="attributes">
                <attribute name="required">l10n_latam_document_auth_required</attribute>
                <attribute name="invisible">not l10n_ec_authorization_number and not l10n_latam_document_auth_required</attribute>
                <attribute name="readonly">not l10n_latam_document_auth_required</attribute>
            </xpath>
            <xpath expr="//field[@name='l10n_ec_sri_payment_id']" position="attributes">
                <attribute name="invisible">country_code != 'EC' or move_type not in ['in_invoice', 'out_invoice']</attribute>
                <attribute name="readonly">state != 'draft'</attribute>
            </xpath>
        </field>
    </record>

    <record id="view_move_form_credit" model="ir.ui.view">
        <field name="name">account.move.form.credit</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="after">
                <field name="l10n_ec_withhold_pending" invisible="1"/>
                <field name="l10n_ec_show_add_withhold" invisible="1"/>
                <div class="alert alert-danger" role="alert" style="margin-bottom:2px;" invisible="not l10n_ec_withhold_pending or move_type != 'in_invoice'">
                    <div class="o_row" invisible="not l10n_ec_withhold_pending or move_type != 'in_invoice'">
                        Esta factura está pendiente de la recepción del documento de retención por parte del cliente.
                        <button name="l10n_ec_add_withhold" string="Agregar Retención" type="object"
                                class="oe_link oe_inline"
                                groups="account.group_account_invoice"
                                invisible="not l10n_ec_show_add_withhold or state != 'posted'"/>
                    </div>
                </div>
            </xpath>

            <div class="oe_button_box" position="inside">
                <button type="object" class="oe_stat_button" name="action_view_credit_notes" icon="fa-plus" invisible="not credit_note_count">
                    <div class="o_field_widget o_stat_info">
                        <span class="o_stat_value">
                            <field name="credit_note_count"/>
                        </span>
                        <span class="o_stat_text">Notas de Crédito</span>
                    </div>
                </button>
            </div>

            <xpath
                expr="//group[@name='sale_info_group']/field[@name='ref']"
                position="after"
            >
                <field
                    name="reason_id"
                    invisible="reason_id == False"
                />
            </xpath>
        </field>
    </record>

    <record id="view_out_invoice_tree_withhold_pending_inherit" model="ir.ui.view">
        <field name="name">account.move.tree.inherit</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_out_invoice_tree"/>
        <field name="arch" type="xml">
            <field name="state" position="before">
                <field name="l10n_ec_withhold_pending" optional="hide" widget="boolean_toggle"/>
            </field>
        </field>
    </record>

    <record id="view_out_credit_note_tree_withhold_pending_inherit" model="ir.ui.view">
        <field name="name">account.move.tree.inherit</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_out_credit_note_tree"/>
        <field name="arch" type="xml">
            <field name="state" position="before">
                <field name="l10n_ec_withhold_pending" optional="hide" widget="boolean_toggle"/>
            </field>
        </field>
    </record>

    <record id="view_in_invoice_refund_tree_withhold_pending_inherit" model="ir.ui.view">
        <field name="name">account.move.tree.inherit</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_in_invoice_refund_tree"/>
        <field name="arch" type="xml">
            <field name="state" position="before">
                <field name="l10n_ec_withhold_pending" optional="hide" widget="boolean_toggle"/>
            </field>
        </field>
    </record>

    <record id="view_account_withhold_pending_filter" model="ir.ui.view">
        <field name="name">account.invoice.select.inherit</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_account_invoice_filter"/>
        <field name="arch" type="xml">
            <xpath expr="//search/group/filter[@name='status']" position="after">
                <separator/>

                <filter string="Documentos pendientes de retención" name="withhold_pending" groups="base.group_no_one"
                        domain="[('l10n_ec_withhold_pending', '=', True)]"/>

                <filter
                    string="Payment Mode"
                    name="payment_mode_groupby"
                    context="{'group_by': 'payment_mode_id'}"
                />
            </xpath>

        </field>
    </record>

    <record id="view_base_zero_invoice_tree" model="ir.ui.view">
        <field name="name">account.invoice.base.zero.tree</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_invoice_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='amount_untaxed_signed']" position="after">
                <field name="l10n_latam_amount_untaxed_zero" sum="Total" optional="hide"/>
                <field name="l10n_latam_amount_untaxed_not_charged_vat" sum="Total" optional="hide"/>
                <field name="l10n_latam_amount_untaxed_exempt_vat" sum="Total" optional="hide"/>
                <field name="l10n_latam_amount_untaxed_not_zero" sum="Total" optional="hide"/>
                <field name="l10n_latam_amount_vat" sum="Total" optional="hide"/>
                <field name="payment_mode_id" optional="hide" />
            </xpath>
        </field>
    </record>

    <record model="ir.ui.view" id="account_move_form_view">
        <field name="name">account.move.form</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='invoice_line_ids']/tree/field[@name='analytic_distribution']" position="after">
                <button name="ek_l10n_ec.action_view_account_move_update_analytic"
                        icon="fa-refresh"
                        string="Analítica"
                        type="action"
                        groups="analytic.group_analytic_accounting"
                        column_invisible="parent.state != 'posted'"
                />
            </xpath>
            <field name="partner_bank_id" position="before">
                <field
                    name="payment_mode_id"
                    domain="[('payment_type', '=', payment_mode_filter_type_domain), ('company_id', '=', company_id)]"
                    widget="selection"
                    readonly="has_reconciled_items"
                    invisible="move_type not in ['out_invoice', 'out_refund', 'in_invoice', 'in_refund']"/>
                <field name="has_reconciled_items" invisible="1" />
                <field name="bank_account_required" invisible="1" />
                <field name="payment_mode_filter_type_domain" invisible="1" />
                <field name="partner_bank_filter_type_domain" invisible="1" />
            </field>
            <xpath
                expr="//group[@id='header_right_group']//field[@name='partner_bank_id']"
                position="attributes"
            >
                <attribute name="context">
                    {'default_partner_id':commercial_partner_id}
                </attribute>
                <attribute name="domain">
                    [('partner_id', '=', partner_bank_filter_type_domain),
                    '|',('company_id', '=', company_id),('company_id', '=', False)]
                </attribute>
                <attribute
                    name="required"
                >bank_account_required and move_type in ['in_invoice', 'in_refund']</attribute>
                <attribute name="readonly">state != 'draft'</attribute>
                <attribute
                    name="invisible"
                >move_type not in ['in_invoice', 'in_refund', 'in_receipt']</attribute>
            </xpath>
            <xpath
                expr="//page[@id='other_tab']//field[@name='partner_bank_id']"
                position="attributes"
            >
                <attribute name="context">
                    {'default_partner_id':commercial_partner_id}
                </attribute>
                <attribute name="domain">
                    [('partner_id', '=', partner_bank_filter_type_domain),
                    '|',('company_id', '=', company_id),('company_id', '=', False)]
                </attribute>
            </xpath>
        </field>
    </record>

    <record model="ir.ui.view" id="account_move_line_tree_view">
        <field name="name">account.move.line.tree</field>
        <field name="model">account.move.line</field>
        <field name="inherit_id" ref="account.view_move_line_tree"/>
        <field name="arch" type="xml">
            <field name="analytic_distribution" position="after">
                <!-- <field name="parent_state" invisible="1"/>-->
                <button name="ek_l10n_ec.action_view_account_move_update_analytic"
                        string="Update Analytic"
                        type="action"
                        groups="analytic.group_analytic_accounting"

                />
            </field>
            <field name="date_maturity" position="after">
                <field name="account_type" column_invisible="True" />
                <field name="reconciled" column_invisible="True" />
                <field
                    name="payment_mode_id"
                    optional="hide"
                    force_save="1"
                    invisible="account_type not in ['asset_receivable', 'liability_payable']"
                    readonly="account_type not in ['asset_receivable', 'liability_payable'] or reconciled == True"

                />
            </field>
        </field>
    </record>

    <record id="view_move_line_form" model="ir.ui.view">
        <field name="name">account_payment_partner.move_line_form</field>
        <field name="model">account.move.line</field>
        <field name="inherit_id" ref="account.view_move_line_form" />
        <field name="arch" type="xml">
            <xpath expr="//field[@name='analytic_distribution']/.." position="after">
                <group name="payments" string="Payments">
                    <field name="account_type" invisible="1" />
                    <field name="reconciled" invisible="1" />
                    <field
                        name="payment_mode_id"
                        force_save="1"
                        invisible="account_type not in ['asset_receivable', 'liability_payable']"
                        readonly="account_type not in ['asset_receivable', 'liability_payable'] or reconciled == True"

                    />
                </group>
            </xpath>
        </field>
    </record>
    <record id="view_move_form_analytic_fix" model="ir.ui.view">
        <field name="name">account.move.form.analytic.fix.ek.l10n.ec</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@id='aml_tab']//field[@name='line_ids']/tree/field[@name='analytic_distribution']" position="attributes">
                <attribute name="options">{'account_field': 'account_id', 'amount_field': 'balance'}</attribute>
            </xpath>
            <xpath expr="//page[@id='aml_tab']//field[@name='line_ids']/tree/field[@name='analytic_distribution']" position="before">
                 <field name="price_subtotal" column_invisible="1"/>
            </xpath>
        </field>
    </record>
</odoo>