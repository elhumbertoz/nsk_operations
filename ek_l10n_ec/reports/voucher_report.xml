<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <template id="report_voucher_document">
            <t t-call="web.external_layout">
                <t t-foreach="docs" t-as="o">
                    <div class="page" style="margin:15px; padding:10px; border:3px solid #ccc; border-radius:10px;">
                        <h3 style="text-align:center;">
                            <span t-if="o.payment_type == 'inbound'">Receipt Voucher</span>
                            <span t-if="o.payment_type == 'outbound'">Payment Voucher</span>
                            <span t-if="o.name">No.
                                <span t-field="o.name"/>
                            </span>
                        </h3>
                        <div class="row">
                            <div class="col-xs-9">
                                <p>
                                    <strong>
                                        <span t-if="o.payment_type == 'inbound'">Paid by:</span>
                                        <span t-if="o.payment_type == 'outbound'">Paid to:</span>
                                    </strong>
                                    <span t-field="o.partner_id"/>
                                    <t t-if="o.partner_id.street">- Address:
                                        <span t-field="o.partner_id.contact_address"/>
                                    </t>
                                </p>
                            </div>
                            <div class="col-xs-9">
                                <p>
                                    <strong>
                                        <span t-if="o.payment_type == 'inbound'">Paid to:</span>
                                        <span t-if="o.payment_type == 'outbound'">Paid by:</span>
                                    </strong>
                                    <span t-field="o.company_id"/>
                                    <t t-if="o.company_id.sudo().partner_id.street">- Address:
                                        <span t-field="o.company_id.sudo().partner_id.contact_address"/>
                                    </t>
                                </p>
                            </div>
                            <div class="col-xs-4">
                                <strong>Payment Date:</strong>
                                <p t-field="o.date"/>
                            </div>
                            <div class="col-xs-4" t-if="o.ref">
                                <strong>Reference/Description:</strong>
                                <p t-field="o.ref"/>
                            </div>
                        </div>
                        <hr size="4" width="90%"/>
                        <p>
                            <span t-if="o.payment_type == 'inbound'">Received from</span>
                            <span t-if="o.payment_type == 'outbound'">Paid to</span>
                            <strong>
                                <span t-field="o.partner_id"/>
                            </strong>
                            <t t-if="o.partner_id.street">- Address:
                                <span t-field="o.partner_id.contact_address"/>
                            </t>
                        </p>
                        <p>Amount of
                            <strong>
                                <span t-field="o.amount"/>
                                <span t-field="o.currency_id"/>
                            </strong>
                            Payment method
                            <strong>
                                <span t-field="o.journal_id"/>
                            </strong>
                            <span t-if="o.ref">
                                With Reference/as value of
                                <strong>
                                    <span t-field="o.ref"/>
                                </strong>
                            </span>
                        </p>
                    </div>
                    <hr size="4" width="90%"/>
                    <div class="row" style="text-align:center;">
                        <div class="col-xs-4">
                            <strong>Responsable:</strong>
                            <p>.......................</p>
                        </div>
                        <div class="col-xs-4">
                            <strong>Contador:</strong>
                            <p t-field="o.create_uid"/>
                        </div>
                        <div class="col-xs-4">
                            <strong>Recibí conforme:</strong>
                            <p t-field="o.partner_id"/>
                        </div>
                    </div>
                </t>
            </t>
        </template>

        <template id="report_voucher">
            <t t-call="web.html_container">
                <t t-foreach="docs" t-as="o">
                    <t t-set="inside_foreach_docs" t-value="o"/>
                    <t t-call="ek_l10n_ec.report_voucher_document" t-lang="o.partner_id.sudo().lang"/>
                </t>
            </t>
        </template>
    </data>
</odoo>