<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record model="ir.module.category" id="module_category_type_object">
        <field name="name">Type Object</field>
        <field name="description">Type All Object Definitions</field>
        <field name="sequence">14</field>
    </record>

    <record id="group_type_object_user" model="res.groups">
        <field name="name">User</field>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        <field name="category_id" ref="ek_base_type_object.module_category_type_object"/>
    </record>

    <record id="group_type_object_manager" model="res.groups">
        <field name="name">Administrator</field>
        <field name="category_id" ref="ek_base_type_object.module_category_type_object"/>
        <field name="implied_ids" eval="[(4, ref('group_type_object_user')),
            (4, ref('mail.group_mail_template_editor'))]"/>
        <field name="users" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
    </record>

    <record id="base.default_user" model="res.users">
        <field name="groups_id" eval="[(4, ref('ek_base_type_object.group_type_object_user'))]"/>
    </record>
</odoo>