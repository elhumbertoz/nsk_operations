<?xml version="1.0"?>
<odoo>

    <record id="ek_l10n_stages_mixin_view_tree" model="ir.ui.view">
        <field name="name">ek.l10n.stages.mixin.tree</field>
        <field name="model">ek.l10n.stages.mixin</field>
        <field name="arch" type="xml">
            <tree string="Stage" multi_edit="1" sample="1" delete="0">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="type_ids"  widget="many2many_tags" optional="show"/>
                <field name="template_id" options="{'no_create': True}" optional="hide"/>
                <field name="fold" optional="show"/>
            </tree>
        </field>
    </record>

    <record id="ek_l10n_stages_mixin_view_search" model="ir.ui.view">
        <field name="name">ek.l10n.stages.mixin.search</field>
        <field name="model">ek.l10n.stages.mixin</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="type_ids"/>
                <field name="template_id" domain="[('model', '=', 'ek.l10n.model.mixin')]"/>
                <filter string="Archived" name="active" domain="[('active', '=' ,False)]"/>
            </search>
        </field>
    </record>

    <record id="ek_l10n_stages_mixin_view_kanban" model="ir.ui.view">
        <field name="name">ek.l10n.stages.mixin.kanban</field>
        <field name="model">ek.l10n.stages.mixin</field>
        <field name="arch" type="xml">
            <kanban>
                <field name="sequence" widget="handle"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_global_click oe_kanban_content">
                            <strong class="o_kanban_record_title">
                                <field name="name"/>
                            </strong>
                            <div>
                                <field name="type_ids" widget="many2many_tags"/>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="ek_l10n_stages_mixin_view_form" model="ir.ui.view">
        <field name="name">ek.l10n.stages.mixin.form</field>
        <field name="model">ek.l10n.stages.mixin</field>
        <field name="arch" type="xml">
            <form string="Stage Search" delete="0">
                <field name="active" invisible="1" />
                <sheet>
                    <div class="oe_button_box" name="button_box" invisible="not context.get('display_stat_button', False)">
                        <button class="oe_stat_button" type="object" name="action_open_objects" icon="fa-life-ring" invisible="object_count == 0">
                            <field name="object_count" widget="statinfo" string="Object"/>
                        </button>
                    </div>
                    <widget name="web_ribbon" title="Archived" bg_color="text-bg-danger" invisible="active" />
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="template_id" context="{'default_model': 'ek.l10n.model.mixin'}"/>
                            <field name="report_id" context="{'default_model': 'ek.l10n.model.mixin'}"/>
                            <field name="sequence" groups="base.group_no_one"/>
                        </group>
                        <group>
                            <field name="fold" widget="toggle_boolean"/>
                            <field name="canceled_stage" widget="toggle_boolean"/>
                            <field name="confirm_stage" widget="toggle_boolean"/>
                            <field name="show_canceled_button" widget="toggle_boolean"/>
                            <field name="show_close_button" widget="toggle_boolean"/>
                            <field name="show_back_button" widget="toggle_boolean"/>
                            <field name="type_ids" widget="many2many_tags" />
                        </group>
                    </group>                    
                </sheet>
            </form>
        </field>
    </record>

    <record id="unlink_ek_l10n_stages_mixin_action" model="ir.actions.server">
        <field name="name">Delete</field>
        <field name="model_id" ref="ek_base_type_object.model_ek_l10n_model_mixin"/>
        <field name="binding_model_id" ref="ek_base_type_object.model_ek_l10n_stages_mixin"/>
        <field name="binding_view_types">form,list</field>
        <field name="state">code</field>
        <field name="code">action = records.action_unlink_wizard(stage_view=True)</field>
    </record>

    <record id="ek_l10n_stages_mixin_action" model="ir.actions.act_window">
        <field name="name">Stages</field>
        <field name="res_model">ek.l10n.stages.mixin</field>
        <field name="view_mode">tree,form,kanban</field>
        <field name="search_view_id" ref="ek_l10n_stages_mixin_view_search"/>
        <field name="context">{'display_stat_button': True}</field>
        <field name="help" type="html">
          <p class="o_view_nocontent_smiling_face">
            No stages found. Let's create one!
          </p><p>
            Adapt your pipeline to your workflow and track the progress of your tickets.
          </p>
        </field>
    </record>

</odoo>
