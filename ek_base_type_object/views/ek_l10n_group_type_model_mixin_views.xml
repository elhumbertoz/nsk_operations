<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- View ek.l10n.group.type.model.mixin View Tree -->
    <record id="view_ek_l10n_group_type_model_mixin_tree" model="ir.ui.view">
        <field name="name">view.ek.l10n.group.type.model.mixin.tree</field>
        <field name="model">ek.l10n.group.type.model.mixin</field>
        <field name="arch" type="xml">
            <tree>
                <field name="code"/>
                <field name="name"/>
            </tree>
        </field>
    </record>

    <!-- View ek.l10n.group.type.model.mixin form -->
    <record id="view_ek_l10n_group_type_model_mixin_form" model="ir.ui.view">
        <field name="name">view.ek.l10n.group.type.model.mixin.form</field>
        <field name="model">ek.l10n.group.type.model.mixin</field>
        <field name="arch" type="xml">
            <form string="Ek L10n Group Type Model Mixin">
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="code" class="oe_inline" placeholder="Code"/>
                        </h1>
                        <h1>
                            <field name="name" placeholder="Name..."/>
                        </h1>
                        
                        
                    </div>
                    <field name="type_ids" nolabel="1">
                        <tree>
                            <field name="code"/>
                            <field name="name"/>
                        </tree>
                    </field>
                </sheet>
            </form>
        </field>
    </record>

    <!-- View ek.l10n.group.type.model.mixin search -->
    <record id="view_ek_l10n_group_type_model_mixin_search" model="ir.ui.view">
        <field name="name">view.ek.l10n.group.type.model.mixin.search</field>
        <field name="model">ek.l10n.group.type.model.mixin</field>
        <field name="arch" type="xml">
            <search>
                <group expand="1" string="Group By">
                    <filter string="Name" name="name" domain="[]" context="{'group_by':'name'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action ek.l10n.group.type.model.mixin -->
    <record id="action_ek_l10n_group_type_model_mixin" model="ir.actions.act_window">
        <field name="name">Groups Type</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">ek.l10n.group.type.model.mixin</field>
        <field name="view_mode">tree,form</field>
        <field name="domain">[]</field>
        <field name="context">{}</field>
    </record>

</odoo>
