<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <record id="view_change_journal_wizard_form" model="ir.ui.view">
    <field name="name">change.journal.wizard.form</field>
    <field name="model">change.journal.wizard</field>
    <field name="arch" type="xml">
      <form string="Cambiar Diario de Facturas">
        <group>
          <field name="journal_id" options="{'no_create': True, 'no_create_edit': True}" widget="many2one"/>
        </group>
        <footer>
          <button name="action_change_journal" string="Cambiar Diario" type="object" class="btn-primary" icon="fa-check"/>
          <button string="Cancelar" class="btn-secondary" special="cancel"/>
        </footer>
      </form>
    </field>
  </record>

  <!-- Acción de ventana (sin binding para que no aparezca en el menú) -->
  <record id="action_change_journal_wizard" model="ir.actions.act_window">
    <field name="name">Cambiar Diario</field>
    <field name="res_model">change.journal.wizard</field>
    <field name="view_mode">form</field>
    <field name="target">new</field>
    <!-- Sin binding_model_id para que no aparezca directamente en el menú -->
  </record>

  <!-- Acción del servidor con binding (sin groups_id - se configura desde la aplicación) -->
  <record id="server_action_change_journal_wizard" model="ir.actions.server">
    <field name="name">Cambiar Diario</field>
    <field name="model_id" ref="account.model_account_move"/>
    <field name="binding_model_id" ref="account.model_account_move"/>
    <field name="binding_view_types">list,form</field>
    <field name="state">code</field>
    <field name="code">
action = env["ir.actions.actions"]._for_xml_id('ek_l10n_ec_purchase_reimbursement.action_change_journal_wizard')
action
    </field>
    <!-- groups_id se configura desde la aplicación -->
  </record>
</odoo>

