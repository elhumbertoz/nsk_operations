<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- View ek.purchase.reimbursement.wizard form -->
    <record id="view_ek_purchase_reimbursement_wizard_form" model="ir.ui.view">
        <field name="name">view.ek.purchase.reimbursement.wizard.form</field>
        <field name="model">ek.purchase.reimbursement.wizard</field>
        <field name="arch" type="xml">
            <form string="Importador de Documentos de Reembolsos">
                <header>
                    <h5>
                        <b>Se importaran las compras correspondientes a los reembolsos pendientes para clientes especificos</b>
                    </h5>
                </header>
                <sheet>
                    <group col="2">
                        <group>
                            <field name="partner_id" readonly="1" force_save="1"/>
                        </group>
                        <group>
                            <field name="invoice_id" readonly="1" force_save="1"/>
                            <field name="allow_purchase_ids" invisible="1"/>
                        </group>
                    </group>
                    <field name="purchase_ids" nolabel="1" col="2" domain="[('id', 'in' , allow_purchase_ids)]">
                        <tree edit="0" create="0" options="{'no_create':True,'no_open':True}">
                            <field name="name" readonly="1"/>
                            <field name="partner_id"/>
                            <field name="date_order"/>
                            <field column_invisible="1" name="currency_id"/>
                            <field name="amount_total" sum="Total" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                            <field name="state"/>
                        </tree>                        
                    </field>
                </sheet>
                <footer>
                    <button name="action_import_from_purchase" type="object" string="Importar" class="oe_highlight"/>
                    <button special="cancel" string="Cancelar"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Action ek.purchase.reimbursement.wizard -->
    <record id="action_ek_purchase_reimbursement_wizard" model="ir.actions.act_window">
        <field name="name">Importar Reembolsos</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">ek.purchase.reimbursement.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

</odoo>
