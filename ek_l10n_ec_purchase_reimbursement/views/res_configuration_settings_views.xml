<?xml version="1.0" encoding="utf-8"?>
  <odoo>
      
    <record id="ek_l10n_ec_purchase_reimbursement_config_settings_view_form" model="ir.ui.view">
        <field name="name">ek.l10n.ec.purchase.reimbursement.res.config.settings.inherit</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="account.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//block[@id='invoicing_settings']" position="after">
                <block id="purchase_reimbursement" title="Reembolsos desde Compras" invisible="country_code != 'EC'">
                    <setting company_dependent="1" string="Configuraciones para documentos de reembolsos desde compras" help="Configuraciones para documentos de reembolsos desde compras">
                        <div class="content-group mt-2">
                            <div class="row">
                                <label for="l10n_ec_reimbursement_journal_ids" class="col-lg-4 o_light_label" string="Diario Permitidos para reembolso"/>
                                <field name="l10n_ec_reimbursement_journal_ids" widget="many2many_tags"/>
                            </div>
                            <div class="row">
                                <label for="l10n_ec_ats_sustento_ids" class="col-lg-4 o_light_label" string="Sustentos Permitidos"/>
                                <field name="l10n_ec_ats_sustento_ids" widget="many2many_tags" />
                            </div>
                            <div class="row">
                                <label for="l10n_ec_assumed_retention_account_prefix" class="col-lg-4 o_light_label" string="Prefijo Cta. Retención Asumida"/>
                                <field name="l10n_ec_assumed_retention_account_prefix"/>
                            </div>
                        </div>
                    </setting>                    
                </block>
            </xpath>
        </field>
    </record>

  </odoo>