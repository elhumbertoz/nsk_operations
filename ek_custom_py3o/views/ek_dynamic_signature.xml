<odoo>
    <data>
        <record id="view_ek_template_py3o_form" model="ir.ui.view">
            <field name="name">view.ek.template.py3o.form</field>
            <field name="model">ek.template.py3o</field>
            <field name="type">form</field>
            <field name="arch" type="xml">
                <form string="">
                    <sheet>

                        <group>
                            <field name="name"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="action_report_id"/>
                            <field name="ek_detail_template_items_ids">
                                <tree string="" editable="bottom">
                                    <field name="type_id"/>
                                    <field name="required"/>
                                    <field name="responsible_id"/>
                                    <field name="page"/>
                                    <field name="posX"/>
                                    <field name="posY"/>
                                    <field name="width"/>
                                    <field name="height"/>
                                    <field name="name_field"/>
                                    <field name="model_res_partner" optional="hide"/>
                                </tree>
                            </field>

                        </group>

                    </sheet>
                </form>
            </field>
        </record>

        <!--
       tree model
    -->
        <record id="view_ek_template_py3o_tree" model="ir.ui.view">
            <field name="name">view.ek.template.py3o.tree</field>
            <field name="model">ek.template.py3o</field>
            <field name="type">tree</field>
            <field name="arch" type="xml">
                <tree string="">
                    <field name="name"/>
                    <field name="company_id" />
                </tree>
            </field>
        </record>

        <!--
       search model
    -->

        <record id="action_ek_template_py3o" model="ir.actions.act_window">
            <field name="name">Posiciones</field>
            <field name="res_model">ek.template.py3o</field>
            <field name="view_mode">tree,form</field>
            <field name="context">{}</field>
            <field name="domain">[]</field>
        </record>



        <menuitem  parent="base.menu_custom"
                  id="menu_action_ek_template_py3o_principal"
                  name="Configuración Firma Electronica" sequence="600"/>

        <menuitem action="action_ek_template_py3o"
                  id="menu_action_ek_template_py3o"
                  parent="menu_action_ek_template_py3o_principal"
                  sequence="601"/>
    </data>
</odoo>