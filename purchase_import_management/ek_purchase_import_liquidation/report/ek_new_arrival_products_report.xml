<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

    <record id="view_ek_new_arrival_products_report_tree" model="ir.ui.view">
        <field name="name">ek.new.arrival.product.tree</field>
        <field name="model">ek.new.arrival.product</field>
        <field name="arch" type="xml">
            <tree string="Productos arribados en los últimos 90 dias" create="0" delete="0" edit="0">
                <field name="name"/>
                <field name="product_id"/>
                <field name="date_done"/>
                <field name="qty_done"/>
                <field name="qty_stock"/>
                <field name="reserved"/>
                <field name="available"/>
                <field name="price"/>
            </tree>
        </field>
    </record>


    <record id="view_ek_new_arrival_products_report_search" model="ir.ui.view">
        <field name="name">ek.new.arrival.product.search</field>
        <field name="model">ek.new.arrival.product</field>
        <field name="arch" type="xml">
            <search string="Productos en Transito">
                <field name="date_done"/>
                <filter name="filter_date" date="date_done" default_period="this_month"/>
                <filter string="Últimos 90 dias" name="year" domain="[('date_done', '&gt;=', (context_today() + relativedelta(days=-90)).strftime('%Y-%m-%d')),('date_done', '&lt;', context_today().strftime('%Y-%m-%d'))]"/>
                <filter string="Último Mes" name="month" domain="[('date_done', '&gt;=', (context_today() + relativedelta(days=-30)).strftime('%Y-%m-%d')),('date_done', '&lt;', context_today().strftime('%Y-%m-%d'))]"/>
                <separator/>
                <field name="product_id"/>
                <field name="name"/>
                <field name="partner_id"/>
                <group expand="0" string="Extended Filters">
                    <field name="company_id" groups="base.group_multi_company"/>
                </group>
                <group expand="1" string="Group By">
                    <filter string="Producto" name="product_id" context="{'group_by':'product_id'}"/>
                    <filter string="Proveedor" name="partner_id" context="{'group_by':'partner_id'}"/>
                    <filter string="Compañía" name="company" groups="base.group_multi_company" context="{'group_by':'company_id'}"/>
                    <separator/>
                    <filter string="Fecha LLegada" name="date_done" context="{'group_by':'date_done'}"/>
                </group>
            </search>
        </field>
    </record>
    <record id="ek_new_arrival_products_report_action" model="ir.actions.act_window">
        <field name="name">Últimas Importaciones (90 dias)</field>
        <field name="res_model">ek.new.arrival.product</field>
        <field name="view_mode">tree</field>
        <field name="context">{'search_default_year': True}</field>
        <field name="view_id" ref="view_ek_new_arrival_products_report_tree"/>
        <field name="search_view_id" ref="view_ek_new_arrival_products_report_search"/>
    </record>

        <!-- This Menu Item must have a parent and an action -->
        <menuitem id="menu_ek_new_arrival_products_report_action" parent="sale.menu_sale_report" action="ek_new_arrival_products_report_action" sequence="10" groups="hr.group_hr_manager" />

    </data>
</odoo>