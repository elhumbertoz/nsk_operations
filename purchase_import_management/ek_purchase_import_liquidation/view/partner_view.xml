<odoo>
    <record id="act_res_partner_2_liq_order" model="ir.actions.act_window">
        <field name="name">Liquidaciones de Importación</field>
        <field name="res_model">ek.import.liquidation</field>
        <field name="view_mode">tree,form</field>
        <field name="context">{'search_default_partner_id': active_id}</field>
        <field name="groups_id" eval="[(4, ref('ek_purchase_import_liquidation.group_user_import_orders'))]"/>
        <field name="help" type="html">
            <p class="oe_view_nocontent_create">
                Click para crear una nueva importación
            </p>
            <p>
                Importaciones
            </p>
        </field>
    </record>

    <record model="ir.ui.view" id="purchase_liq_2_partner_kanban_view">
        <field name="name">res.partner.kanban.liq.purchaseorder.inherit</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.res_partner_kanban_view"/>
        <field name="arch" type="xml">
            <field name="mobile" position="after">
                <field name="purchase_liq_import_count"/>
            </field>
            <xpath expr="//div[hasclass('oe_kanban_bottom_left')]" position="inside">
                <a name="%(ek_purchase_import_liquidation.act_res_partner_2_liq_order)d" type="action"
                   gropus="ek_purchase_import_liquidation.group_user_import_orders"
                   t-if="record.purchase_liq_import_count.value>0">
                    <t t-esc="record.purchase_liq_import_count.value"/>
                    Importaciones
                </a>
            </xpath>
        </field>
    </record>

    <record id="act_res_partner_2_supplier_liq_invoices" model="ir.actions.act_window">
        <field name="name">Facturas del Exterior</field>
        <field name="res_model">account.move</field>
        <field name="view_mode">tree,form</field>
        <field name="context">{'search_default_partner_id': active_id, 'default_type': 'liquidation', 'type': 'liquidation'}</field>
        <field name="help" type="html">
            <p class="oe_view_nocontent_create">
                Click para crear una nueva factura de importación
            </p>
            <p>
                Facturas
            </p>
        </field>
    </record>

    <record id="res_partner_view_liq_purchase_import_buttons" model="ir.ui.view">
        <field name="name">res.partner.view.liq.purchase.buttons</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="priority" eval="20"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button class="oe_inline oe_stat_button"
                        name="%(ek_purchase_import_liquidation.act_res_partner_2_liq_order)d"
                        type="action"
                        groups="ek_purchase_import_liquidation.group_admin_purchase_import_liquidation"
                        icon="fa-ship">
                    <field string="Importaciones" name="purchase_liq_import_count" widget="statinfo"/>
                </button>
            </xpath>
        </field>
    </record>

    <record id="res_partner_view_liq_purchase_account_buttons" model="ir.ui.view">
        <field name="name">res.partner.view.liq.purchase.account.buttons</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="priority" eval="20"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button class="oe_inline oe_stat_button"
                        name="%(account.action_move_in_invoice_type)d"
                        type="action" help="Facturas del exterior."
                        icon="fa-files-o"
                        groups="ek_purchase_import_liquidation.group_admin_purchase_import_liquidation"
                        context="{'search_default_partner_id': active_id, 'default_move_type': 'in_invoice', 'search_default_invoice_liquidation': 1}">
                    <field string="Fac. del Exterior." name="supplier_liq_invoice_count" widget="statinfo"/>
                </button>
            </xpath>
        </field>
    </record>

    <record id="res_partner_view_liq_purchase_ref_import" model="ir.ui.view">
        <field name="name">base.view_partner_form</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="priority" eval="25"/>
        <field name="arch" type="xml">
            <xpath expr="//span[@name='address_name']" position="before">
                <field name="ref_import"
                       groups="ek_purchase_import_liquidation.group_user_import_orders,ek_purchase_import_liquidation.group_confirm_import_operator"/>
            </xpath>
        </field>
    </record>
</odoo>
