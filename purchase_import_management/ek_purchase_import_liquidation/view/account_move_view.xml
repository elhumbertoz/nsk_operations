<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_account_invoice_liquidation_filter" model="ir.ui.view">
        <field name="name">account.move.select</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_account_invoice_filter"/>
        <field name="arch" type="xml">
            <field name="partner_id" position="after">
                <field name="import_liquidation_id"/>
                <field name="terms_id"/>
            </field>
            <xpath expr="//filter[@name='to_check']" position="after">
                <filter string="Fact. Importación" name="invoice_liquidation" domain="[('invoice_liquidation_id', '!=', False)]"/>
                <filter string="Docs. Importación" name="docs_liquidation" domain="[('import_liquidation_id', '!=', False)]"/>
            </xpath>
            <group>
                <filter string="Docs. Importación" name="liquidation_id" domain="[('import_liquidation_id', '!=', False)]"
                        context="{'group_by': 'import_liquidation_id'}"/>
                <filter string="Términos de Importación" name="terms_id" domain="[('import_liquidation_id', '!=', False)]"
                        context="{'group_by': 'terms_id'}"/>
            </group>
        </field>
    </record>

    <record id="filter_invoice_docs_import_2" model="ir.filters">
        <field name="name">Docs. Importación y Facturas</field>
        <field name="model_id">account.move</field>
        <field name="domain">['|',('invoice_liquidation_id', '!=', False),('import_liquidation_id', '!=', False)]</field>
        <field name="user_id" eval="False"/>
<!--        <field name="context">{'group_by': ['invoice_liquidation_id', 'import_liquidation_id']}</field>-->
    </record>

    <record id="view_account_move_invoice_liquidation_filter" model="ir.ui.view">
        <field name="name">account.move.filter</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_account_move_filter"/>
        <field name="arch" type="xml">
            <field name="partner_id" position="after">
                <field name="import_liquidation_id"/>
                <field name="terms_id"/>
            </field>
            <group>
                <filter string="Importación" name="liquidation_id" domain="[('import_liquidation_id', '!=', False)]"
                        context="{'group_by': 'import_liquidation_id'}"/>
                <filter string="Términos de Importación" name="terms_id" domain="[('import_liquidation_id', '!=', False)]"
                        context="{'group_by': 'terms_id'}"/>
            </group>
        </field>
    </record>

    <record id="view_move_liquidation_form" model="ir.ui.view">
        <field name="name">account.move.form</field>
        <field name="model">account.move</field>
        <field name="priority" eval="1000"/>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <field name="invoice_vendor_bill_id" position="after">
                    <label for="invoice_liquidation_id" class="oe_edit_only"
                           invisible="invoice_liquidation_id == False"
                           readonly="1" />

                    <field name="invoice_liquidation_id" nolabel="1"
                               invisible="invoice_liquidation_id == False"
                                class="oe_edit_only" readonly="1" options="{'no_open': True, 'no_create': True}"/>

                    <label for="apply_import" class="oe_edit_only"
                           invisible="move_type not in ['in_invoice', 'in_refund'] or invoice_liquidation_id != False"
                           readonly="state != 'draft'" />

                    <field name="apply_import" nolabel="1"
                           invisible="move_type not in ['in_invoice', 'in_refund'] or invoice_liquidation_id != False"
                           readonly="state != 'draft'"
                           class="oe_edit_only"
                           widget="boolean_toggle"
                        />



                    <label for="import_liquidation_id" class="oe_edit_only"
                           invisible="apply_import != True"
                           readonly="state != 'draft'" />

                    <field name="import_liquidation_id" nolabel="1"
                               invisible="apply_import != True"
                               required="apply_import"
                                class="oe_edit_only"
                               readonly="state == 'posted'"
                               domain="[('state', 'in', ['draft','calculate']), ('type', '=', 'liquidation')]"
                               options="{'no_open': True, 'no_create': True}"/>

                <label for="terms_id" class="oe_edit_only"
                           invisible="apply_import != True"
                           readonly="state != 'draft'" />

                    <field name="terms_id"
                               invisible="apply_import != True"
                                nolabel="1"
                               readonly="state == 'posted'"
                               required="import_liquidation_id"
                                class="oe_edit_only"
                               options="{'no_open': True, 'no_create': True}"/>
            </field>
        </field>
    </record>
</odoo>