<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="view_ek_generate_purchase_suggest_wizard" model="ir.ui.view">
            <field name="name">ek.generate.purchase.suggest.wizard.form</field>
            <field name="model">ek.generate.purchase.suggest.wizard</field>
            <field name="arch" type="xml">
                <form string="Sugerido de Compra">
                    <group colspan="2" name="info_group">
                        <div class="alert alert-info mb-0" role="alert" name="info_div" colspan="2">
                            <ul colspan="4" name="info_ul">
                                <li name="info_li01">
                                    Si selecciona un proveedor en específico solo se calculara el sugerido para los productos donde se encuentre detallo el proveedor indicado.
                                </li>
                                <li invisible="partner_id != False"  name="info_li02">
                                    La <b>clasificación de proveedores</b> es usada para identificar o sugerir el mejor proveedor en caso de que un mismo producto posea más de un proveedor
                                </li>
                                <li  name="info_li03">
                                    Si selecciona una categoría de producto solo se mostraran aquellos productos que pertenezcan a la misma
                                </li>
                                <li invisible="all_product != True" name="info_li04">
                                    Si marca la opción <b>Todos los productos</b> se mostrarán todos los productos existentes
                                </li>
                                <li invisible="product_out_of_stock != True"  name="info_li05">
                                    Si marca la opción <b>Productos sin stock</b> se mostrarán solo los productos que se encuentren si stock
                                </li>
                                <li invisible="product_with_suggested != True" name="info_li06">
                                    Si marca la opción <b>Productos Sugeridos</b> se mostrarán solo los productos que el sugerido calculado sea mayor a cero
                                </li>
                                <li invisible="product_with_last_date != True" name="info_li07">
                                    Si marca la opción <b>Productos con movimientos</b> se mostrarán todos los productos que han tenido movimientos en la cantidad de dias especificada
                                </li>
                                <li name="info_li08">
                                    La <b>Fecha de Corte</b> indica desde cuando se obtendrán los datos de ventas para el cálculo del sugerido
                                </li>
                                <li  name="info_li09">
                                    La <b>Fecha de pedido</b> indica tentativamente cuando se realizaría el pedido al proveedor, basado en esta se calcula la fecha de llegada estimada
                                </li>
                            </ul>
                        </div>
                    </group>
                    <group>
                        <group name="action_group">
                            <field name="partner_id"/>
                            <field name="only_partner" widget="boolean_toggle" invisible="not partner_id"/>
                            <field name="method" invisible="partner_id != False" required="1"/>
                            <field name="date" required="1"/>
                            <field name="date_order" required="1"/>
                            <field name="categ_ids"  widget="many2many_tags"/>
                            <field name="warehouse_ids" widget="many2many_tags"/>
                            <field name="round_type" required="1"/>
                            <field name="precision_digits"/>
                        </group>
                         <group name="action_group">
                             <field name="type" required="1"/>
                             <field name="type_sale_qty" 
                               invisible="type != 'sale'"
                               required="type == 'sale'"
                             />
                             <field name="based_in_liquidation" widget="boolean_toggle"/>
                             <field name="all_product" widget="boolean_toggle"/>
                             <field name="product_out_of_stock"
                                invisible="all_product != False"
                                 widget="boolean_toggle"/>
                             <field name="product_with_suggested" 
                             invisible="all_product != False" widget="boolean_toggle"/>
                             <field name="product_with_last_date"
                             invisible="all_product != False" widget="boolean_toggle"/>
                             <label for="day_with_last_date" string="(días desde el último movimiento)"
                             invisible="product_with_last_date == False" />
                             <field name="day_with_last_date" nolabel="1" class="oe_inline" style="width:50px !important" 
                             invisible="product_with_last_date == False"/>
                        </group>
                    </group>
                    <footer>
                        <button name="action_create_suggest" string="Generar Sugerido" type="object" class="oe_highlight"
                                confirm="Esta seguro que la información está correcta." data-hotkey="w" 
                                 context="{'open_purchase': True}"/>
                        <button string="Cancelar" class="oe_link" special="cancel" data-hotkey="z"/>
                    </footer>
                </form>
            </field>
        </record>

        <record id="action_generate_suggest_wizard" model="ir.actions.act_window">
            <field name="name">Generar Sugerido de Compras</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">ek.generate.purchase.suggest.wizard</field>
            <field name="view_mode">form</field>
            <field name="view_id" ref="view_ek_generate_purchase_suggest_wizard"/>
            <field name="target">new</field>
        </record>


        <menuitem action="action_generate_suggest_wizard" id="menu_action_asigned_purchase_order_wizardn"
            parent="suggest_purchase_root"
            sequence="1"/>
    </data>
</odoo>