<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <record model="ir.cron" id="cron_days_out_of_stock_suggested_purchase">
            <field name="name">[Sugerido de compra] - Cálculo de dias sin stock</field>
            <field name="model_id" ref = "model_ek_days_out_of_stock"/>
            <field name="state">code</field>
            <field name="code">model.cron_check_days_out_of_stock()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="numbercall">-1</field>
            <field name="nextcall" eval="(DateTime.now() + relativedelta(day=1)).strftime('%Y-%m-%d 05:00:00')" />
        </record>

    </data>
</odoo>