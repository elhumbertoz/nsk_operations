<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_llm_provider_tree" model="ir.ui.view">
        <field name="name">nsk.llm.provider.tree</field>
        <field name="model">nsk.llm.provider</field>
        <field name="arch" type="xml">
            <tree string="LLM Providers">
                <field name="name"/>
                <field name="provider_type"/>
                <field name="model_name"/>
                <field name="active" widget="boolean_toggle"/>
            </tree>
        </field>
    </record>

    <record id="view_llm_provider_form" model="ir.ui.view">
        <field name="name">nsk.llm.provider.form</field>
        <field name="model">nsk.llm.provider</field>
        <field name="arch" type="xml">
            <form string="LLM Provider">
                <header>
                    <button name="action_test_connection" type="object" string="Test Connection" class="oe_highlight"/>
                </header>
                <sheet>
                    <widget name="web_ribbon" title="Archived" bg_color="bg-danger" invisible="active"/>
                    <div class="oe_title">
                        <label for="name" class="oe_edit_only"/>
                        <h1>
                            <field name="name" placeholder="e.g. My GPT-4o Connection"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="active" invisible="1"/>
                            <field name="provider_type"/>
                            <field name="model_name"/>
                        </group>
                        <group>
                            <field name="api_key" widget="password"/>
                            <field name="api_base" placeholder="https://api.openai.com/v1"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_llm_provider" model="ir.actions.act_window">
        <field name="name">LLM Providers</field>
        <field name="res_model">nsk.llm.provider</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>
