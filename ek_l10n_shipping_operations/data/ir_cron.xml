<odoo>
    <data noupdate="1">
        <record id="ir_cron_partner_create_reminder" model="ir.cron">
            <field name="name">Expired or expiring document reminder cron Partner</field>
            <field name="model_id" ref="model_res_partner"/>
            <field name="state">code</field>
            <field name="code">model.cron_create_reminder_crew_documents()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">hours</field>
            <field name="numbercall">-1</field>
            <field name="active" eval="True"/>
            <field name="priority" eval="50"/>
        </record>

        <record id="ir_cron_ship_create_reminder" model="ir.cron">
            <field name="name">Expired or expiring document reminder cron Ship </field>
            <field name="model_id" ref="model_ek_ship_registration"/>
            <field name="state">code</field>
            <field name="code">model.cron_create_reminder_ship_documents()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">hours</field>
            <field name="numbercall">-1</field>
            <field name="active" eval="True"/>
            <field name="priority" eval="50"/>
        </record>


        <record id="ir_cron_operation_request_create_reminder" model="ir.cron">
            <field name="name">Expired or expiring document reminder cron Operation Request</field>
            <field name="model_id" ref="model_ek_operation_request"/>
            <field name="state">code</field>
            <field name="code">model.cron_create_activity_recordation_maanagent()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">hours</field>
            <field name="numbercall">-1</field>
            <field name="active" eval="True"/>
            <field name="priority" eval="50"/>
        </record>

        <record id="ir_cron_update_date_today" model="ir.cron">
            <field name="name">Update Date Today</field>
            <field name="model_id" ref="model_common_fields_mixin"/>
            <field name="state">code</field>
            <field name="code">model.update_date_today()</field>
            <field name="interval_type">days</field>
            <field name="interval_number">1</field>
            <field name="numbercall">-1</field>
            <field name="doall" eval="False"/>
            <field name="active" eval="True"/>
        </record>

      
    </data>
</odoo>