  <record id="ek_ship_registration_kanban" model="ir.ui.view">
    <field name="name">ek.ship.registration.kanban</field>
    <field name="model">ek.ship.registration</field>
    <field name="arch" type="xml">
      <kanban class="oe_background_grey o_kanban_dashboard ek_ship_registration_kanban" sample="1">
        <field name="name" />
        <field name="ship_flag_id" />
        <field name="boat_registration" />
        <field name="boat_color" />
        <field name="color" />
        <field name="image_url" />
        <field name="image" />
        <field name="omi"/>
        <field name="type_trafic"/>
        <field name="bussiness_name_id"/>
        <field name="capital_name_id"/>
        <field name="sale_order_count"/>
        <field name="travel_count"/>
        <templates>
          <t t-name="kanban-box">
            <style> 
              .color_kanban_title_ek {
                color:<t t-esc="record.boat_color" />
;
              }
              .o_text_overflow .ship-info-label {
                white-space: pre-wrap !important;
                display: inline-block !important;
              }
              .ship-info-label {
                white-space: pre-wrap !important;
                display: inline-block !important;
              }
            </style>
            <div class="oe_kanban_global_click" style="display: flex; flex-direction: row; gap: .7rem; max-height: 310px; padding: .8rem; overflow: hidden;">
              <div class="oe_kanban_image" style="width: 80%; min-width: 100px; padding: 0;">
                <img t-att-src="record.image.raw_value ? ('/web/image/ek.ship.registration/' + record.id.raw_value + '/image') : '/ek_l10n_shipping_operations/static/src/img/default_ship.png?v=4'" alt="Ship Image" class="o_image_64_contain" style="height: 100%; width: 100%; max-width: none; object-fit: cover; object-position: center; border-radius: 5px;" />
              </div>
              <div class="oe_kanban_details" style="display: flex; flex-direction: column; justify-content: unset; gap: 5px; flex-grow: 1;">
                <!-- Título del buque -->
                <h2>
                  <strong>
                    <div class="color_kanban_title_ek">
                      <field name="name" />
                    </div>
                  </strong>
                </h2>
                <!-- Bandera del país -->
                <div>
                  <div class="o_kanban_image" style="padding-top: 3px;">
                    <field name="image_url" widget="image_url" />
                  </div>
                </div>
                <!-- Información del buque -->
                <ul style="display: flex; flex-direction: column;">
                  <li class="o_text_overflow">
                    <strong class="ship-info-label">Armador:&#160;</strong>
                    <field name="bussiness_name_id" />
                  </li>
                  <li class="o_text_overflow">
                    <strong class="ship-info-label">Propietario:&#160;</strong>
                    <field name="capital_name_id" />
                  </li>
                  <li class="o_text_overflow">
                    <strong class="ship-info-label">OMI:&#160;</strong>
                    <field name="omi" />
                  </li>
                  <li class="o_text_overflow">
                    <strong class="ship-info-label">Matricula:&#160;</strong>
                    <field name="boat_registration" />
                  </li>
                  <li class="o_text_overflow">
                    <strong class="ship-info-label">Tipo de Tráfico:&#160;</strong>
                    <field name="type_trafic" />
                  </li>
                </ul>
                <!-- Estadísticas -->
                <div class="o_kanban_tags_section" style="padding-bottom: .2rem; display: flex; flex-grow: 1; align-items: flex-end;">
                  <span class="badge badge-pill" style="padding-left: 0;">
                    <i class="fa fa-file-text" aria-hidden="true" style="margin-right: 5px; padding-right: 5px;"></i>
                    <field name="sale_order_count" /> Ordenes
                  </span>
                  <span class="badge badge-pill">
                    <i class="fa fa-suitcase" aria-hidden="true" style="margin-right: 5px;"></i>
                    <field name="travel_count" /> Viajes
                  </span>
                </div>
              </div>
            </div>
          </t>
        </templates>
      </kanban>
    </field>
  </record>

