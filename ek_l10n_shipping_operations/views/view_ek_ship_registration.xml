  <record id="ek_ship_document_certificate_tree" model="ir.ui.view">
    <field name="name">ek_ship_document_certificate_tree</field>
    <field name="model">ek.ship.document.certificate</field>
    <field name="arch" type="xml">
      <tree decoration-danger="document_status == 'expired'" decoration-warning="document_status == 'to_wi'">
        <field name="name" />
        <field name="date_issue" string="Emitido" />
        <field name="expiration_date" string="Vencimiento" />
        <field name="next_endorsement_date" optional="hide" />
        <field name="date_limit" optional="hide" />
        <field name="code" optional="hide" />
        <field name="range_from_date" optional="show" />
        <field name="range_to_date" optional="show" />
        <field name="periodicity" optional="hide" />
        <field name="periodicity_type" optional="hide" />
        <field name="alert_time" string="Notificar Antes" optional="show" />
        <field name="alert_time_type" string="Unidad" optional="show" />
        <field name="next_alert_date" string="Próxima Alerta" optional="show" decoration-info="True" />
        <field name="contact_ids" string="Notificar a" widget="many2many_tags" optional="show" />
        <field name="document_status" widget="badge" decoration-danger="document_status == 'expired'" decoration-warning="document_status == 'to_wi'" decoration-success="document_status == 'current'" string="Status" />
      </tree>
    </field>
  </record>

  <record id="ek_ship_document_certificate_form" model="ir.ui.view">
    <field name="name">ek_ship_document_certificate_form</field>
    <field name="model">ek.ship.document.certificate</field>
    <field name="arch" type="xml">
      <form>
        <header>
          <field name="document_status" widget="statusbar" options="{'clickable':1}" />
        </header>
        <sheet>
          <div class="oe_title">
            <h1>
              <field name="name" placeholder="Ship Document Certificate" required="1" />
            </h1>
          </div>
          <group>
            <group string="Información Básica">
              <field name="code" required="0" placeholder="Ej. LST-1234"/>
              <field name="institution_id" placeholder="Ej. DIRNEA, Autoridad Portuaria..."/>
              <field name="date_issue" />
              <field name="expiration_date" />
              <field name="next_endorsement_date" />
              <field name="date_limit" />
              <field name="date_today" invisible="1" />
              <field name="ship_name_id" invisible="1" />
            </group>
            <group string="Configuración de Alertas">
              <label for="range_from_date" string="Rango de Tolerancia" />
              <div class="o_row">
                <span class="oe_inline">Desde </span>
                <field name="range_from_date" class="oe_inline" />
                <span class="oe_inline">  Hasta </span>
                <field name="range_to_date" class="oe_inline" />
              </div>

              <label for="alert_time" string="Notificar Antes del Vencimiento" />
              <div class="o_row">
                <field name="alert_time" class="oe_inline" />
                <field name="alert_time_type" class="oe_inline" />
                <span class="oe_inline ml-2"> a partir de las </span>
                <field name="alert_start_time" widget="float_time" class="oe_inline" placeholder="Ej. 08:30" />
              </div>

              <label for="periodicity" string="Se Renueva Cada" />
              <div class="o_row">
                <field name="periodicity" class="oe_inline" />
                <field name="periodicity_type" class="oe_inline" />
              </div>

              <field name="contact_ids" widget="many2many_tags" />
              <field name="next_alert_date" decoration-info="True" readonly="1" />
              <field name="last_alert_sent_date" readonly="1" string="Fecha de Última Alerta Enviada" />
            </group>
          </group>
          <notebook>
            <page string="Notas">
              <field name="notes" placeholder="Notas detalladas para el correo de alerta... (ej. documentos requeridos, acciones para resolver)" nolabel="1" />
            </page>
          </notebook>
        </sheet>
        <div class="oe_chatter" name="oe_chatter">
          <field name="message_follower_ids" />
          <field name="message_ids" />
          <field name="activity_ids" />
        </div>
      </form>
    </field>
  </record>
</odoo>