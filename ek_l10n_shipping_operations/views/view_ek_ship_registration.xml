<odoo>



  <record id="ek_ship_registration_form" model="ir.ui.view">
    <field name="name">ek.ship.registration.form</field>
    <field name="model">ek.ship.registration</field>
    <field name="arch" type="xml">
      <form>
        <header>
          <field name="state_boats" widget="statusbar" options="{'clickable':1}" />
        </header>
        <div class="alert alert-warning" role="alert" invisible="not ship_document_certificate_count_expired !=  0">
                    THE BOAT REGISTERS DOCUMENTATION EXPIRING OR EXPIRED PLEASE VERIFY AND UPDATE
        </div>
        <sheet>
          <div class="oe_button_box" name="button_box">
            <button class="oe_stat_button" name="action_open_documents_travel" type="object" icon="fa-suitcase">
              <field string="Travel" name="travel_count" widget="statinfo" />
            </button>
            <button class="oe_stat_button" name="action_open_documents_request" type="object" icon="fa-share-square-o">
              <field string="Request" name="request_count" widget="statinfo" />
            </button>
            <button class="oe_stat_button" name="action_open_enhanced_requests" type="object" icon="fa-list-alt">
              <field string="Enhanced Requests" name="request_count" widget="statinfo" />
            </button>
            <button class="oe_stat_button" name="action_open_documents_trip_details_days" type="object" icon="fa-file-text-o">
              <field string="Trip Details Days" name="trip_details_days_count" widget="statinfo" />
            </button>
            <button class="oe_stat_button" name="action_open_ship_document_certificate_count" type="object" icon="fa-file-text-o">
              <field string="Ship Document Certificate" name="ship_document_certificate_count" widget="statinfo" />
            </button>
          </div>
          <!-- <widget name="web_ribbon" title="Navegando" invisible="state_boats == 'port'" />
          <widget name="web_ribbon" title="En Puerto" bg_color="bg-info" invisible="state_boats == 'sailing'" /> -->
          <field name="image" widget="image" class="oe_avatar" options="{'size':[150,150]}" invisible="type_photo in ['helmet','starboard','bow','popa']" />
          <field name="image_1" widget="image" class="oe_avatar" options="{'size':[150,150]}" invisible="type_photo in ['port','starboard','bow','popa']" />
          <field name="image_2" widget="image" class="oe_avatar" options="{'size':[150,150]}" invisible="type_photo in ['port','bow','helmet','popa']" />
          <field name="image_3" widget="image" class="oe_avatar" options="{'size':[150,150]}" invisible="type_photo in ['port','helmet','starboard','popa']" />
          <field name="image_4" widget="image" class="oe_avatar" options="{'size':[150,150]}" invisible="type_photo in ['port','helmet','starboard','bow']" />
          <div class="oe_title">
            <h1>
              <field name="name" placeholder="Nombre de Buque" required="1"/>
            </h1>
          </div>
          <div class="oe_title">
            <h2>
              <field name="ek_boat_location_id" style="width: 100%" force_save="1" readonly="0" placeholder="Ubicacion actual del barco"/>
            </h2>
          </div>
          <group>
            <group>
              <field name="ship_document_certificate_count_expired" invisible="1" />
              <field name="state_boats" invisible="1" force_save="1" />
              <field name="type_photo" required="1" widget="radio" />
              <field name="image_copy" widget="image" invisible="1" force_save="1" />
              <field name="bussiness_name_id" required="1" force_save="1" string="Armador " />
              <field name="capital_name_id" required="1" force_save="1" />
              <field name="boat_color" force_save="1" />
              <field name="ship_flag_id" required="1" force_save="1" />
              <field name="company_id" required="1" groups="base.group_multi_company" />
              <field name="analytic_account_id" force_save="1" options="{'no_edit': True, 'no_create': True, 'no_open': True}" />
              <field name="sequence_id" required="1" domain="[('code','=','BUQUE')]"/>
              <field name="send_notificacion_user_ek" widget="boolean_toggle" />
              <field name="ek_user_groups_reminder_id" invisible="not send_notificacion_user_ek" />
              <!-- Campo removido para ponerlo en el notebook: <field name="ek_ship_document_certificate_ids" invisible="1" /> -->
              <field name="is_practic" widget="boolean_toggle" invisible="assigned_regimen_70" />
              <field name="assigned_regimen_70" widget="boolean_toggle" />
              <label for="fuel" string="Fuel" invisible="assigned_regimen_70" />
              <div invisible="assigned_regimen_70">
                <field name="fuel" force_save="1" class="oe_inline" readonly="0" />
                <field name="fuel_uom" force_save="1" class="oe_inline" readonly="0" />
              </div>

              <label for="gasoline" string="Gasoline" invisible="assigned_regimen_70" />
              <div invisible="assigned_regimen_70">
                <field name="gasoline" force_save="1" class="oe_inline" readonly="0" />
                <field name="gasoline_uom" force_save="1" class="oe_inline" readonly="0" />
              </div>

              <label for="water" string="Water" invisible="assigned_regimen_70" />
              <div invisible="assigned_regimen_70">
                <field name="water" force_save="1" class="oe_inline" readonly="0" />
                <field name="water_uom" force_save="1" class="oe_inline" readonly="0" />
              </div>
            </group>
            <group>
              <button name="action_open_boat_characteristics" type="object" string="Record" class="btn btn-link p-0" icon="fa-bars" invisible="assigned_regimen_70" />
              <button name="action_open_boat_arching" type="object" string="Arching" class="btn btn-link p-0" icon="fa-folder-open" invisible="assigned_regimen_70" />
              <button name="action_open_boat_loading_lines" type="object" string="Loading Lines" class="btn btn-link p-0" icon="fa-cart-arrow-down" invisible="assigned_regimen_70" />
              <button name="action_open_boat_security_equipments" type="object" string="Security Equipments" class="btn btn-link p-0" icon="fa-lock" invisible="assigned_regimen_70" />
              <button name="action_open_gmdss" type="object" string="GMDSS" class="btn btn-link p-0" icon="fa-file-o" invisible="assigned_regimen_70" />
              <button name="action_open_fuel_control" type="object" string="Fuel Control" class="btn btn-link p-0" icon="fa-fire-extinguisher" invisible="assigned_regimen_70" />
              <button name="action_open_boat_contamination" type="object" string="Contamination" class="btn btn-link p-0" icon="fa-globe" invisible="assigned_regimen_70" />
            </group>
          </group>
          <notebook>
            <page string="Minimum Endowment" invisible="assigned_regimen_70">
              <field name="ek_crew_member_hierarchy_number_ids">
                <tree editable="bottom">
                  <field name="name" colspan="6" string="Number" />
                  <field name="ek_crew_member_hierarchy_id" colspan="6" />
                </tree>
              </field>
            </page>
            <page string="Crew Member" invisible="assigned_regimen_70">
              <field name="crew_ids" force_save="1">
                <tree>
                  <field name="name" />
                  <field name="ek_crew_member_hierarchy_id" string="Hierarchy" />
                  <field name="nationality_id"/>
                  <field name="l10n_ec_birthdate"/>
                  <field name="vat" string="ID"/>
                </tree>
              </field>
            </page>
            <page string="Certificados e Inspecciones">
              <field name="ek_ship_document_certificate_ids" context="{'default_ship_name_id': id}">
                <tree decoration-danger="document_status == 'expired'" decoration-warning="document_status == 'to_wi'">
                  <field name="name" />
                  <field name="date_issue" string="Emitido" />
                  <field name="expiration_date" string="Vencimiento" />
                  <field name="range_from_date" string="Rango Desde" optional="show" />
                  <field name="range_to_date" string="Rango Hasta" optional="show" />
                  <field name="alert_time" string="Notificar Antes" optional="show" />
                  <field name="alert_time_type" string="Unidad" optional="show" />
                  <field name="next_alert_date" string="Próxima Alerta" optional="show" decoration-info="True" />
                  <field name="contact_ids" string="Notificar a" widget="many2many_tags" optional="show" />
                  <field name="document_status" widget="badge" decoration-danger="document_status == 'expired'" decoration-warning="document_status == 'to_wi'" decoration-success="document_status == 'current'" string="Status" />
                </tree>
              </field>
            </page>
          </notebook>
        </sheet>
        <div class="oe_chatter" name="oe_chatter">
          <field name="message_follower_ids" />
          <field name="message_ids" />
          <field name="activity_ids" />
        </div>
      </form>
    </field>
  </record>

