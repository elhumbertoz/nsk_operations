<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <!-- Vista de formulario para Seguimiento de Reembolsos -->
  <record id="view_ek_reimbursement_tracking_form" model="ir.ui.view">
    <field name="name">ek.reimbursement.tracking.form</field>
    <field name="model">ek.reimbursement.tracking</field>
    <field name="arch" type="xml">
      <form create="false" edit="false">
        <header>
          <button name="action_recalculate_days" type="object" string="Recalcular Días" class="btn-secondary" icon="fa-refresh"/>
          <button name="action_ignore" type="object" string="Ignorar" class="btn-warning" icon="fa-ban" invisible="state == 'ignored'"/>
          <button name="action_unignore" type="object" string="Designorar" class="btn-primary" icon="fa-undo" invisible="state != 'ignored'"/>
          <field name="state" widget="statusbar" statusbar_visible="draft,purchase_pending,purchase_confirmed,invoice_pending,invoice_received,client_invoice_pending,client_invoice_sent,recovered,ignored"/>
        </header>
        <sheet>
          <div class="oe_button_box" name="button_box">
            <button class="oe_stat_button" type="object" name="action_view_purchase_order" invisible="not purchase_order_id" icon="fa-shopping-cart">
              <field string="Orden de Compra" name="purchase_order_state" widget="statinfo"/>
            </button>
            <button class="oe_stat_button" type="object" name="action_view_invoice" invisible="not invoice_id" icon="fa-file-text-o">
              <field string="Factura" name="invoice_state" widget="statinfo"/>
            </button>
          </div>

          <widget name="web_ribbon" title="Ignorado" bg_color="bg-warning" invisible="state != 'ignored'"/>
          <widget name="web_ribbon" title="Recuperado" bg_color="bg-success" invisible="not state == 'recovered'"/>

          <div class="oe_title">
            <h1>
              <field name="product_default_name" placeholder="Descripción del producto..." readonly="1"/>
            </h1>
          </div>

          <group>
            <group>
              <field name="journey_crew_id" options="{'no_edit': True, 'no_create': True}"/>
              <field name="request_id" options="{'no_edit': True, 'no_create': True}"/>
              <field name="ship_id" readonly="1"/>
              <field name="customer_id" readonly="1"/>
              <field name="supplier_id" options="{'no_edit': True, 'no_create': True}"/>
              <!-- <field name="ignored" invisible="state == 'ignored'"/> -->
              <field name="reason_ignored" invisible="state != 'ignored'" required="state == 'ignored'"/>
            </group>
            <group>
              <field name="amount" readonly="1"/>
              <field name="currency_id" readonly="1"/>
              <field name="responsible_user_id" readonly="1"/>
              <field name="date_created" readonly="1"/>
              <field name="date_expected_invoice" readonly="1"/>
            </group>
          </group>

          <group string="Control de Stages">
            <group>
              <field name="request_stage" readonly="1"/>
              <field name="stage_to_trigger" readonly="1"/>
            </group>
            <group>
              <field name="product_stage_ids" widget="many2many_tags" readonly="1"/>
            </group>
          </group>

          <group>
            <group>
              <field name="days_pending" readonly="1"/>
              <field name="days_range" readonly="1"/>
              <field name="sequence" readonly="1"/>
            </group>
            <group>
              <field name="purchase_order_id" readonly="1"/>
              <field name="invoice_id" readonly="1"/>
            </group>
          </group>
        </sheet>
      </form>
    </field>
  </record>

  <!-- Vista de árbol para Seguimiento de Reembolsos -->
  <record id="view_ek_reimbursement_tracking_tree" model="ir.ui.view">
    <field name="name">ek.reimbursement.tracking.tree</field>
    <field name="model">ek.reimbursement.tracking</field>
    <field name="arch" type="xml">
      <tree decoration-success="ignored or state == 'recovered'" decoration-warning="days_pending &gt; 5 and days_pending &lt;= 15 and not ignored and state not in ['recovered', 'cancelled']" decoration-danger="days_pending &gt; 15 and not ignored and state not in ['recovered', 'cancelled']" decoration-muted="state == 'cancelled'" sample="1" multi_edit="1">
        <header>
          <button name="action_recalculate_all_days" type="object" string="Recalcular Todos los Días" class="btn-secondary"/>
        </header>
        <field name="sequence" widget="handle"/>
        <field name="ship_id" string="Buque"/>
        <field name="journey_crew_id"/>
        <field name="request_id" string="Solicitud"/>
        <field name="product_default_name" string="Producto"/>
        <field name="supplier_id" optional="hide"/>
        <field name="customer_id" optional="hide"/>
        <field name="amount" sum="Total" optional="hide"/>
        <field name="currency_id" optional="hide"/>
        <field name="state" widget="badge" string="Estado" decoration-success="state == 'recovered'" decoration-warning="state in ['purchase_pending', 'invoice_pending', 'client_invoice_pending']" decoration-info="state in ['purchase_confirmed', 'invoice_received', 'client_invoice_sent']"/>
        <field name="request_stage" widget="badge" string="Estado Solicitud"/>
        <field name="days_pending" optional="hide"/>
        <field name="days_range" optional="hide"/>
        <field name="ignored" widget="boolean_toggle" optional="hide"/>
        <field name="reason_ignored" optional="hide"/>
        <field name="responsible_user_id" widget="many2one_avatar_user" optional="hide"/>
        <field name="stage_to_trigger" optional="hide"/>
        <field name="product_stage_ids" widget="many2many_tags" string="Genera en"/>
        <field name="date_created" optional="hide"/>
        <field name="date_expected_invoice" optional="hide"/>
      </tree>
    </field>
  </record>

  <!-- Vista de búsqueda para Seguimiento de Reembolsos -->
  <record id="view_ek_reimbursement_tracking_search" model="ir.ui.view">
    <field name="name">ek.reimbursement.tracking.search</field>
    <field name="model">ek.reimbursement.tracking</field>
    <field name="arch" type="xml">
      <search>
        <field name="product_default_name"/>
        <field name="journey_crew_id"/>
        <field name="request_id"/>
        <field name="supplier_id"/>
        <field name="request_stage"/>
        <field name="stage_to_trigger"/>
        <field name="product_stage_ids"/>

        <filter name="filter_not_recovered" string="Pendientes" domain="[('state', '!=', 'recovered'), ('ignored', '!=', True)]"/>

        <group expand="1" string="Agrupar por">
          <filter name="group_by_ship" string="Buque" context="{'group_by': 'ship_id'}"/>
          <filter name="group_by_journey" string="Viaje" context="{'group_by': 'journey_crew_id'}"/>
          <filter name="group_by_state" string="Estado" context="{'group_by': 'state'}"/>
        </group>
      </search>
    </field>
  </record>

  <!-- Vista kanban para Seguimiento de Reembolsos -->
  <record id="view_ek_reimbursement_tracking_kanban" model="ir.ui.view">
    <field name="name">ek.reimbursement.tracking.kanban</field>
    <field name="model">ek.reimbursement.tracking</field>
    <field name="arch" type="xml">
      <kanban default_group_by="state" class="o_kanban_small_column">
        <field name="journey_crew_id"/>
        <field name="ship_id"/>
        <field name="product_default_name"/>
        <field name="amount"/>
        <field name="currency_id"/>
        <field name="days_pending"/>
        <field name="ignored"/>
        <field name="state"/>
        <field name="responsible_user_id"/>
        <templates>
          <t t-name="kanban-box">
            <div t-attf-class="oe_kanban_card oe_kanban_global_click #{record.ignored.raw_value ? 'oe_kanban_color_9' : ''}">
              <div class="o_dropdown_kanban dropdown">
                <a class="dropdown-toggle o-no-caret btn" role="button" data-bs-toggle="dropdown" href="#" aria-label="Dropdown menu" title="Dropdown menu">
                  <span class="fa fa-ellipsis-v"/>
                </a>
                <div class="dropdown-menu" role="menu">
                  <a role="menuitem" type="edit" class="dropdown-item">Editar</a>
                  <a role="menuitem" type="delete" class="dropdown-item">Eliminar</a>
                </div>
              </div>

              <div class="oe_kanban_content">
                <div class="o_kanban_record_top">
                  <div class="o_kanban_record_headings">
                    <strong class="o_kanban_record_title">
                      <field name="product_default_name"/>
                    </strong>
                    <br/>
                    <small>
                      <field name="journey_crew_id"/>
 -                      <field name="ship_id"/>
                    </small>
                  </div>
                </div>

                <div class="o_kanban_record_body">
                  <div class="row">
                    <div class="col-6">
                      <strong>Monto:</strong>
                      <br/>
                      <field name="currency_id"/>
                      <field name="amount"/>
                    </div>
                    <div class="col-6">
                      <strong>Días:</strong>
                      <br/>
                      <span t-attf-class="badge #{record.days_pending.raw_value > 15 ? 'text-bg-danger' : record.days_pending.raw_value > 5 ? 'text-bg-warning' : 'text-bg-success'}">
                        <field name="days_pending"/>
 días
                      </span>
                    </div>
                  </div>

                  <div class="row mt-2" t-if="record.ignored.raw_value">
                    <div class="col-12">
                      <span class="badge text-bg-warning">
                        <i class="fa fa-eye-slash"/>
 Ignorado
                      </span>
                    </div>
                  </div>
                </div>

                <div class="oe_kanban_footer">
                  <div class="o_kanban_record_bottom">
                    <div class="oe_kanban_bottom_left">
                      <field name="responsible_user_id" widget="many2one_avatar_user"/>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </t>
        </templates>
      </kanban>
    </field>
  </record>

  <!-- Vista pivot para análisis -->
  <record id="view_ek_reimbursement_tracking_pivot" model="ir.ui.view">
    <field name="name">ek.reimbursement.tracking.pivot</field>
    <field name="model">ek.reimbursement.tracking</field>
    <field name="arch" type="xml">
      <pivot string="Análisis de Reembolsos">
        <field name="journey_crew_id" type="row"/>
        <field name="state" type="col"/>
        <field name="amount" type="measure"/>
      </pivot>
    </field>
  </record>

</odoo>
