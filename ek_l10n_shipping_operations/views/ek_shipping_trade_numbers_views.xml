<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- View ek.shipping.trade.numbers View Tree -->
    <record id="view_ek_shipping_trade_numbers_tree" model="ir.ui.view">
        <field name="name">view.ek.shipping.trade.numbers.tree</field>
        <field name="model">ek.shipping.trade.numbers</field>
        <field name="arch" type="xml">
            <tree create="0" edit="0" delete="0">
                <field name="name"/>
                <field name="note" />   
                <field name="user_id"/>   
                <field name="create_date"/>
                <field name="ship_registration_id" optional="hide"/>
                <field name="boats_information_id" optional="hide"/>
                <field name="request_id" optional="hide"/>
                <field name="type_id" optional="hide"/>
                <field name="stage_id" optional="hide"/>
            </tree>
        </field>
    </record>
    <record id="view_ek_shipping_trade_numbers_inherit" model="ir.ui.view">
        <field name="name">ek.shipping.trade.numbers.inherit</field>
        <field name="model">ek.shipping.trade.numbers</field>
        <field name="inherit_id" ref="ek_l10n_shipping_operations.view_ek_shipping_trade_numbers_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//tree" position="attributes">
                <attribute name="js_class">ek_button_js_tree</attribute>
            </xpath>
        </field>
    </record>




