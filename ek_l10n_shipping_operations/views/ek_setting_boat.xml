  <!-- model.name inherit form view -->
  <record id="view_ek_l10n_type_field_mixin_inherit" model="ir.ui.view">
    <field name="name">ek.l10n.type.field.mixin.inherit</field>
    <field name="model">ek.l10n.type.field.mixin</field>
    <field name="inherit_id" ref="ek_base_type_object.view_ek_l10n_type_field_mixin_form"/>
    <field name="arch" type="xml">
      <xpath expr="//field[@name='ttype']" position="after">
        <field name="fields_relation_id" force_save="1" invisible="ttype in ('many2many','one2many')" />
        <field name="fields_change_id" required="fields_relation_id" invisible="not fields_relation_id" domain="domain" force_save="1"/>
        <field name="stage_id" invisible="not fields_relation_id" required="fields_change_id" force_save="1" widget="many2many_tags"/>
        <field name="domain" force_save="1" invisible="1" />
      </xpath>
    </field>
  </record>

  <record id="ek_l10n_stages_mixin_inherit" model="ir.ui.view">
    <field name="name">ek.l10n.stages.mixi.inherit.form</field>
    <field name="model">ek.l10n.stages.mixin</field>
    <field name="inherit_id" ref="ek_base_type_object.ek_l10n_stages_mixin_view_form"/>
    <field name="arch" type="xml">
      <xpath expr="//field[@name='sequence']" position="after">
        <field name="readonly_mass"/>
      </xpath>
    </field>
  </record>
