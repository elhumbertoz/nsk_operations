  <record id="ek_group_mail_template_form" model="ir.ui.view">
    <field name="name">ek_group_mail_template_form</field>
    <field name="model">ek.group.mail.template</field>
    <field name="type">form</field>
    <field name="arch" type="xml">
      <form>
        <sheet>
          <div class="oe_title">
            <h1>
              <field name="name" placeholder="Name" required="1" />
            </h1>
          </div>
          <group>
            <group>
              <field name="partner_id"/>
            </group>
            <group>
              <field name="res_partner_id" widget="many2many_tags" />
            </group>
          </group>
        </sheet>
      </form>
    </field>
  </record>

  <record id="ek_group_mail_template_tree" model="ir.ui.view">
    <field name="name">ek_group_mail_template_tree</field>
