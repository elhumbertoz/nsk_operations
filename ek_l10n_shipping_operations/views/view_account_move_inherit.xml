<odoo>
    <record id="shipping_operations_account_move_form_view_inherit" model="ir.ui.view">
        <field name="name">account.move.inherit.form</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='ref']" position="after">
                <field name="ship_name_id" force_save="1" string="Buque"   options="{'no_quick_create': True, 'no_create_edit': True, 'no_open': True}"/>
                <field name="journey_crew_id" force_save="1"  options="{'no_quick_create': True, 'no_create_edit': True, 'no_open': True}"/>
                <field name="operation_request_id" force_save="1"   options="{'no_quick_create': True, 'no_create_edit': True, 'no_open': True}"/>
                <field name="crew_id_domain" invisible="1" />
            </xpath>
            <xpath expr="//field[@name='line_ids']/tree[1]/field[@name='analytic_distribution']"
                   position="after">
                <field name="ship_name_id" force_save="1" string="Buque"  options="{'no_quick_create': True, 'no_create_edit': True, 'no_open': True}"/>
                <field name="journey_crew_id" force_save="1"  options="{'no_quick_create': True, 'no_create_edit': True, 'no_open': True}"/>
                <button name="update_line_travel_ship" type="object" icon="fa-refresh" />
            </xpath>
            <xpath expr="//field[@name='invoice_line_ids']/tree[1]/field[@name='quantity']"
                   position="before">
                <field name="ship_name_id" force_save="1" string="Buque"  options="{'no_quick_create': True, 'no_create_edit': True, 'no_open': True}"/>
                <field name="journey_crew_id" force_save="1"  options="{'no_quick_create': True, 'no_create_edit': True, 'no_open': True}"/>
                <button name="update_line_travel_ship" type="object" icon="fa-refresh" />
            </xpath>
        </field>
    </record>

    <record id="shipping_operations_payment_form_view_inherit" model="ir.ui.view">
        <field name="name">account.payment.inherit.form</field>
        <field name="model">account.payment</field>
        <field name="inherit_id" ref="account.view_account_payment_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='ref']" position="after">
                <field name="ship_name_id"  string="Buque" force_save="1"   options="{'no_quick_create': True, 'no_create_edit': True, 'no_open': True}"/>
                <field name="journey_crew_id" force_save="1"   options="{'no_quick_create': True, 'no_create_edit': True, 'no_open': True}"/>
            </xpath>
        </field>
    </record>

    <record id="shipping_account_move_line_tree_view_inherit" model="ir.ui.view">
        <field name="name">account.move.line.inherit.form</field>
        <field name="model">account.move.line</field>
        <field name="inherit_id" ref="account.view_move_line_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='analytic_distribution']" position="after">
                <field name="ship_name_id" string="Buque" force_save="1"  options="{'no_quick_create': True, 'no_create_edit': True, 'no_open': True}"/>
                <field name="journey_crew_id" force_save="1"  options="{'no_quick_create': True, 'no_create_edit': True, 'no_open': True}"/>
            </xpath>
        </field>
    </record>

</odoo>